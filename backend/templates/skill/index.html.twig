{% extends 'base.html.twig' %}

{% block title %}Gestion des compétences
{% endblock %}

{% block body %}
	<main
		class="p-8 bg-gray-50 min-h-screen">
		<!-- Header -->
		<div class="flex justify-between items-center mb-8">
			<h1 class="text-2xl font-bold text-gray-800 flex items-center space-x-2">
				<span class="material-icons text-teal-600">psychology</span>
				<span>Gestion des compétences</span>
			</h1>
			<a href="{{ path('skill_create') }}" class="px-5 py-2 bg-gradient-to-r from-teal-600 to-green-600 text-white rounded-lg shadow hover:scale-105 transform transition flex items-center space-x-2">
				<span class="material-icons">add_circle</span>
				<span>Ajouter une compétence</span>
			</a>
		</div>

		<!-- Flash Messages -->
		{% for message in app.flashes('success') %}
			<div class="mb-4 p-4 bg-green-100 border border-green-400 text-green-700 rounded-lg">
				{{ message }}
			</div>
		{% endfor %}
		{% for message in app.flashes('error') %}
			<div class="mb-4 p-4 bg-red-100 border border-red-400 text-red-700 rounded-lg">
				{{ message }}
			</div>
		{% endfor %}

		<!-- Table -->
		<div class="bg-white rounded-xl shadow overflow-hidden">
			<table class="min-w-full text-left">
				<thead class="bg-gray-100 text-gray-600 uppercase text-sm sticky top-0">
					<tr>
						<th class="px-6 py-3">Id</th>
						<th class="px-6 py-3">Nom</th>
						<th class="px-6 py-3">Niveau</th>
						<th class="px-6 py-3">Actions</th>
					</tr>
				</thead>
				<tbody class="divide-y divide-gray-200">
					{% for skill in skills %}
						<tr class="hover:bg-gray-50 transition">
							<td class="px-6 py-4 text-gray-700">{{ skill.id }}</td>
							<td class="px-6 py-4 font-semibold text-gray-800">{{ skill.name }}</td>
							<td class="px-6 py-4 text-gray-600">{{ skill.level }}</td>
							<td class="px-6 py-4 flex space-x-3">
								<a href="{{ path('skill_read', {'id': skill.id}) }}" class="px-3 py-1 bg-blue-100 text-blue-700 rounded-lg hover:bg-blue-200 transition flex items-center space-x-1 text-sm">
									<span class="material-icons text-sm">visibility</span>
									<span>Détails</span>
								</a>
								<a href="{{ path('skill_update', {'id': skill.id}) }}" class="px-3 py-1 bg-yellow-100 text-yellow-700 rounded-lg hover:bg-yellow-200 transition flex items-center space-x-1 text-sm">
									<span class="material-icons text-sm">edit</span>
									<span>Modifier</span>
								</a>
								<!-- ✅ FORMULAIRE POST POUR LA SUPPRESSION -->
								<form method="post" action="{{ path('skill_delete', {'id': skill.id}) }}" onsubmit="return confirm('Voulez-vous vraiment supprimer cette compétence ?');" class="inline-block">
									<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ skill.id) }}">
									<button type="submit" class="px-3 py-1 bg-red-100 text-red-700 rounded-lg hover:bg-red-200 transition flex items-center space-x-1 text-sm">
										<span class="material-icons text-sm">delete</span>
										<span>Supprimer</span>
									</button>
								</form>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="4" class="px-6 py-12 text-center">
								<div class="flex flex-col items-center space-y-3">
									<span class="material-icons text-gray-400 text-5xl">inbox</span>
									<p class="text-gray-500">Aucune compétence trouvée</p>
									<a href="{{ path('skill_create') }}" class="px-4 py-2 bg-teal-600 text-white rounded-lg shadow hover:bg-teal-700 transition">
										Ajouter une compétence
									</a>
								</div>
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>

		<!-- Pagination -->
		<div class="flex justify-center items-center mt-6 space-x-2">
			<a href="#" class="px-3 py-1 rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition">&laquo;</a>
			<a href="#" class="px-3 py-1 rounded-lg bg-teal-600 text-white shadow">1</a>
			<a href="#" class="px-3 py-1 rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition">2</a>
			<a href="#" class="px-3 py-1 rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition">3</a>
			<a href="#" class="px-3 py-1 rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition">&raquo;</a>
		</div>
	</main>
{% endblock %}
