{% extends 'base.html.twig' %}

{% block title %}Détails de la compétence
{% endblock %}

{% block body %}
	<main
		class="p-8 bg-gray-50 min-h-screen">

		<!-- Header -->
		<div class="flex justify-between items-center mb-8">
			<h1 class="text-2xl font-bold text-gray-800 flex items-center space-x-2">
				<span class="material-icons text-teal-600">psychology</span>
				<span>Détails de la compétence</span>
			</h1>
			<a href="{{ path('skill_index') }}" class="px-5 py-2 bg-gray-200 text-gray-700 rounded-lg shadow hover:bg-gray-300 transition flex items-center space-x-2">
				<span class="material-icons">arrow_back</span>
				<span>Retour à la liste</span>
			</a>
		</div>

		<!-- Card détails -->
		<div class="bg-white p-8 rounded-xl shadow-lg border border-gray-100 space-y-6">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				<div>
					<p class="text-sm text-gray-500">ID</p>
					<p class="text-lg font-semibold text-gray-800">{{ skill.id }}</p>
				</div>
				<div>
					<p class="text-sm text-gray-500">Nom</p>
					<p class="text-lg font-semibold text-gray-800">{{ skill.name }}</p>
				</div>
				<div>
					<p class="text-sm text-gray-500">Niveau</p>
					<p class="text-lg font-semibold text-gray-800">{{ skill.level }}</p>
				</div>
			</div>
		</div>

		<!-- Actions -->
		<div class="flex space-x-4 mt-6">
			<a href="{{ path('skill_update', {'id': skill.id}) }}" class="px-5 py-2 bg-yellow-100 text-yellow-700 rounded-lg shadow hover:bg-yellow-200 transition flex items-center space-x-2">
				<span class="material-icons">edit</span>
				<span>Modifier</span>
			</a>
			{{ include('skill/_delete_form.html.twig') }}
		</div>
	</main>
{% endblock %}

