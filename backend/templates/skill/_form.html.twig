<div class="bg-white p-6 rounded-lg shadow-md border border-gray-100">
	{{ form_start(form, {'attr': {'class': 'space-y-4'}}) }}

	<div>
		<label class="block text-sm font-medium text-gray-700 mb-1">Nom de la compétence</label>
		{{ form_widget(form.name, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-teal-600 focus:outline-none'}}) }}
		{% if form_errors(form.name) %}
			<p class="text-red-600 text-xs mt-1">{{ form_errors(form.name) }}</p>
		{% endif %}
	</div>

	<div>
		<label class="block text-sm font-medium text-gray-700 mb-1">Niveau</label>
		{{ form_widget(form.level, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-teal-600 focus:outline-none'}}) }}
		<p class="text-xs text-gray-500 mt-1">Indique ton niveau de maîtrise (ex. débutant, intermédiaire, avancé).</p>
		{% if form_errors(form.level) %}
			<p class="text-red-600 text-xs mt-1">{{ form_errors(form.level) }}</p>
		{% endif %}
	</div>

	<div>
		<label class="block text-sm font-medium text-gray-700 mb-1">Catégorie</label>
		{{ form_widget(form.skillCategory, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-teal-600 focus:outline-none'}}) }}
		{% if form_errors(form.skillCategory) %}
			<p class="text-red-600 text-xs mt-1">{{ form_errors(form.skillCategory) }}</p>
		{% endif %}
	</div>

	<div>
		{{ form_label(form.projects, 'Projets associés', {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 mb-2'}}) }}
		{{ form_widget(form.projects, {'attr': {'class': 'w-full px-4 py-2.5 bg-slate-50 border border-slate-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:bg-white focus:outline-none'}}) }}
		{{ form_errors(form.projects, {'attr': {'class': 'text-red-600 text-xs mt-1'}}) }}
	</div>

	<div class="flex justify-end">
		<button class="px-5 py-2 bg-gradient-to-r from-teal-600 to-green-600 text-white rounded-md shadow hover:scale-105 transform transition flex items-center space-x-2">
			<span class="material-icons text-sm">save</span>
			<span>{{ button_label|default('Enregistrer') }}</span>
		</button>
	</div>

	{{ form_end(form) }}
</div>