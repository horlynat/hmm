<!DOCTYPE html>
<html lang="fr" class="{{ app.request.attributes.get('_route') starts with 'profile' ? 'dark' : '' }}">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>
			{% block title %}Login | Admin
			{% endblock %}
		</title>

		<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
		<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">

		{% block stylesheets %}
			{{ vite_entry_link_tags('login') }}
		{% endblock %}

		{% block javascripts %}
			{{ vite_entry_script_tags('login') }}
		{% endblock %}
	</head>
	<body class="h-screen bg-bg-default">

		<div class="login-container">
			<!-- Colonne gauche -->
			<div class="flex items-center justify-center bg-linear-to-br from-blue-900 via-indigo-700 to-purple-600 relative overflow-hidden">
				<div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.15),transparent_70%)] animate-pulse"></div>

				<svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 128 128" class="w-full max-w-xl mx-auto drop-shadow-[0_0_25px_rgba(59,130,246,0.6)] transform transition-transform duration-700 hover:rotate-3 hover:scale-105">
					<defs>
						<linearGradient id="lockGradient" x1="0" y1="0" x2="0" y2="1">
							<stop offset="0%" stop-color="#1e3a8a"/>
							<stop offset="100%" stop-color="#3b82f6"/>
						</linearGradient>
					</defs>

					<!-- Serrure hyper sécurisée -->
					<rect x="40" y="50" width="48" height="50" rx="8" fill="url(#lockGradient)" stroke="#0f172a" stroke-width="2"/>
					<path d="M48 50v-12a16 16 0 0 1 32 0v12" fill="none" stroke="#0f172a" stroke-width="3"/>

					<circle cx="64" cy="75" r="10" fill="#fff" stroke="#1e3a8a" stroke-width="2"/>
					<circle cx="64" cy="75" r="4" fill="#1e3a8a"/>
					<path d="M64 79v6" stroke="#1e3a8a" stroke-width="2"/>

					<circle cx="64" cy="75" r="20" fill="none" stroke="#3b82f6" stroke-width="1.5" stroke-dasharray="4 3" opacity="0.6"/>
					<circle cx="64" cy="75" r="30" fill="none" stroke="#60a5fa" stroke-width="1" stroke-dasharray="2 2" opacity="0.4"/>

					<rect x="28" y="65" width="8" height="8" rx="2" fill="#3b82f6"/>
					<rect x="92" y="65" width="8" height="8" rx="2" fill="#3b82f6"/>
					<circle cx="64" cy="110" r="5" fill="#3b82f6"/>

					<line x1="36" y1="69" x2="54" y2="75" stroke="#3b82f6" stroke-width="1.5" opacity="0.6"/>
					<line x1="92" y1="69" x2="74" y2="75" stroke="#3b82f6" stroke-width="1.5" opacity="0.6"/>
					<line x1="64" y1="105" x2="64" y2="90" stroke="#3b82f6" stroke-width="1.5" opacity="0.6"/>

					<circle cx="64" cy="64" r="58" fill="none" stroke="#3b82f6" stroke-width="1" stroke-dasharray="4 4" opacity="0.3"/>
				</svg>
			</div>

			<!-- Colonne droite -->
			<div class="flex items-center justify-center px-0 py-12 lg:px-8">
				<div class="w-full max-w-md bg-white/80 backdrop-blur-xl shadow-2xl rounded-2xl p-10 border border-white/30">
					<h1 class="text-center text-3xl font-extrabold tracking-tight text-blue-900 mb-8">
						🔐 Connexion Sécurisée
					</h1>

					{% if error %}
						<div class="mb-4 p-3 bg-red-100 text-red-700 rounded-lg border border-red-300 text-sm">
							{{ error.messageKey|trans(error.messageData, 'security') }}
						</div>
					{% endif %}

					<form id="loginForm" method="post" class="space-y-6">
						<!-- Email -->
						<div class="relative">
							<label for="inputEmail" class="label block">E-mail : </label>
							<input type="email" id="inputEmail" name="email" value="{{ last_username }}" autocomplete="email" required autofocus class="input input-email input-primary w-full" placeholder="Votre adresse email" aria-describedby="emailHelper"/>
							<p id="emailHelper" class="text-sm mt-1"></p>
						</div>

						<!-- Mot de passe -->
						<div class="relative">
							<label for="inputPassword" class="label block">Mot de passe : </label>
							<input type="password" id="inputPassword" name="password" autocomplete="current-password" required class="input input-password input-primary  w-full" placeholder="••••••••" aria-describedby="passwordHelper"/>
							<p id="passwordHelper" class="text-sm mt-1"></p>
						</div>

						<!-- CSRF -->
						<input
						type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

						<!-- Remember me -->
						<div class="flex items-center justify-between">
							<span class="flex items-center space-x-2">
								<input type="checkbox" id="remember_me" name="_remember_me" class="input-checkbox "/>
								<label for="remember_me" class="label">Se souvenir de moi</label>
							</span>
							<a href="#" class="text-sm font-semibold text-brand-primary hover:underline">
								Mot de passe oublié ?
							</a>
						</div>

						<!-- Bouton principal -->
						<button type="submit" class="btn btn-primary w-full">
							🚀 Connexion
						</button>
					</form>

					<!-- Connexion sociale -->
					<div class="mt-10">
						<div class="relative">
							<div class="absolute inset-0 flex items-center">
								<div class="w-full border-t border-gray-300"></div>
							</div>
							<div class="relative flex justify-center text-sm">
								<span class="bg-white px-2 text-gray-500">Ou continuez avec</span>
							</div>
						</div>

						<div
							class="mt-6 grid grid-cols-2 gap-4">
							<!-- Google -->
							<a
								href="#" class="flex justify-center items-center rounded-full border border-gray-300 bg-white p-3 shadow hover:shadow-blue-500/40 transition">
								<!-- Icône Google -->
								<svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 48 48" class="h-6 w-6">
									<path fill="#EA4335" d="M24 9.5c3.94 0 6.58 1.7 8.1 3.13l5.9-5.9C34.5 3.5 29.7 1.5 24 1.5 14.5 1.5 6.5 7.5 3.5 15.5l7.4 5.7C12.5 14.5 17.7 9.5 24 9.5z"/>
									<path fill="#4285F4" d="M46.5 24c0-1.6-.1-3.1-.4-4.5H24v9h12.8c-.6 3.2-2.5 5.9-5.3 7.7l8.2 6.4c4.8-4.4 7.8-10.9 7.8-18.6z"/>
									<path fill="#FBBC05" d="M10.9 29.2c-1.1-3.2-1.1-6.6 0-9.8l-7.4-5.7C1.1 17.5 0 20.6 0 24c0 3.4 1.1 6.5 3.5 10.3l7.4-5.1z"/>
									<path fill="#34A853" d="M24 47c6.5 0 12-2.1 16-5.7l-8.2-6.4c-2.2 1.5-5 2.4-7.8 2.4-6.3 0-11.5-4.3-13.4-10.1l-7.4 5.1C6.5 40.5 14.5 47 24 47z"/>
								</svg>
							</a>

							<!-- GitHub -->
							<a href="#" class="flex justify-center items-center rounded-full border border-gray-300 bg-white p-3 shadow hover:shadow-blue-500/40 transition">
								<svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewbox="0 0 24 24" class="h-6 w-6 text-gray-800">
									<path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2.1c-3.2.7-3.9-1.5-3.9-1.5-.5-1.2-1.2-1.5-1.2-1.5-1-.7.1-.7.1-.7 1.1.1 1.7 1.1 1.7 1.1 1 .1.7 1.7 2.7 1.2.1-.7.4-1.2.7-1.5-2.6-.3-5.3-1.3-5.3-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.6.1-3.3 0 0 1-.3 3.3 1.2a11.4 11.4 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.7.2 3 .1 3.3.7.8 1.2 1.9 1.2 3.2 0 4.6-2.7 5.6-5.3 5.9.4.3.8 1 .8 2.1v3.1c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"/>
								</svg>
							</a>
						</div>

						<p class="mt-6 text-center text-sm text-gray-500">Pas encore de compte ? <a href="{{ path('register') }}" class="font-semibold text-blue-900 hover:underline">Inscrivez-vous</a></p>
					</div>
				</div>
			</div>
		</div>
	</body>
</html>

