<header class="flex justify-between items-center mb-8 bg-white-950/80 backdrop-blur-md shadow-sm px-8 py-4 sticky top-0 z-40">

	<div class="flex flex-col md:flex-row md:items-center gap-4 flex-1">
		<nav class="text-sm text-gray-500">
			<a href="{{ path('dashboard_index') }}" class="hover:text-blue-600">Accueil</a>
			{% set segments = app.request.pathInfo|trim('/')|split('/') %}
			{% for segment in segments %}
				<span class="mx-2">/</span>
				<span class="capitalize text-gray-800 font-medium">{{ segment|replace({'_': ' '}) }}</span>
			{% endfor %}
		</nav>

		<div class="relative flex-1 max-w-sm">
			<span class="material-icons absolute left-3 top-2 text-gray-400 text-sm">search</span>
			<input type="text" placeholder="Rechercher..." class="w-full pl-10 pr-4 py-1.5 rounded-lg border border-gray-200 focus:ring-2 focus:ring-indigo-500 focus:outline-none transition text-sm shadow-sm">
		</div>
	</div>

	<div class="flex items-center space-x-4">

		<button class="relative p-2 rounded-lg bg-gray-100 hover:bg-gray-200 transition text-gray-600">
			<span class="material-icons text-lg">event</span>
			<span class="absolute top-1.5 right-1.5 w-2 h-2 bg-red-500 rounded-full"></span>
		</button>

		<button class="relative p-2 rounded-lg bg-gray-100 hover:bg-gray-200 transition text-gray-600">
			<span class="material-icons text-lg">request_quote</span>
			<span class="absolute top-1.5 right-1.5 w-2 h-2 bg-red-500 rounded-full"></span>
		</button>

        {# Définition des variables #}
        {% set firstName = app.user ? app.user.email|split('@')[0]|capitalize : 'Visiteur' %}
        {% set userRole = app.user ? (app.user.roles|first|replace({'ROLE_': ''})|lower|capitalize) : 'Guest' %}

        <div
            class="relative" x-data="{ open: false }">
            <!-- Bouton déclencheur au clic -->
            <button @click="open = !open" class="flex items-center gap-3 rounded-full border border-gray-200 px-4 py-1.5 bg-white hover:bg-gray-50 transition cursor-pointer shadow-sm">

                <img src="https://ui-avatars.com/api/?name={{ firstName }}&background=1e3a8a&color=fff" alt="Avatar" class="w-8 h-8 rounded-full border border-gray-200">

                <div class="text-left pr-1">
                    <p class="text-xs font-bold text-gray-800">{{ firstName }}</p>
                    <p class="text-[10px] text-gray-500 uppercase tracking-wider">{{ userRole }}</p>
                </div>

                <span class="material-icons text-sm text-gray-400">expand_more</span>
            </button>

            <!-- Menu déroulant (visible si open est true) -->
            <div x-show="open" @click.away="open = false" class="absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-xl border border-gray-100 z-50 py-2">

                <a href="#" class="flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-900 transition">
                    <span class="material-icons text-base mr-3 opacity-70">person</span>
                    Mon profil
                </a>

                <a href="#" class="flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-900 transition">
                    <span class="material-icons text-base mr-3 opacity-70">settings</span>
                    Paramètres
                </a>

                <hr class="my-1 border-gray-100">

                <a href="{{ path('logout') }}" class="flex items-center px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition">
                    <span class="material-icons text-base mr-3 opacity-70">logout</span>
                    Déconnexion
                </a>
            </div>
        </div>

	</div>
</header>
