<header class="flex justify-between items-center bg-bg-default backdrop-blur-md px-6 py-4 sticky top-0 z-40">

	<!-- Zone gauche : URL + Nom de page -->
	<div class="flex items-center space-x-6">
		<!-- Fil d’Ariane -->
		<nav class="flex items-center text-sm text-gray-500 px-3 py-1.5">
			<!-- Icône Home -->
			<a href="{{ path('dashboard_index') }}" class="flex items-center text-brand-primary font-bold hover:text-brand-accent transition">
				<span class="material-icons text-base mr-1">home</span>
				Home
			</a>

			<!-- Segments dynamiques -->
			{% set segments = app.request.pathInfo|trim('/')|split('/') %}
			{% for segment in segments %}
				<span class="mx-2 text-gray-400">/</span>
				<span class="capitalize text-brand-dark font-medium">
					{{ segment|replace({'_': ' '}) }}
				</span>
			{% endfor %}
		</nav>
	</div>

	<!-- Zone droite : Recherche + Icônes -->
	<div class="flex items-center space-x-4">

		<!-- Barre de recherche -->
		<div class="relative">
			<input type="text" placeholder="Rechercher..." class="input input-search w-72 shadow-sm focus:ring-2 focus:ring-brand-primary"/>
		</div>

		<!-- Icône demandes -->
		<a href="#" class="relative p-2 hover:bg-brand-light/30 transition text-brand-dark" aria-label="Demandes">
			<span class="material-icons text-xl">inbox</span>
		</a>

		<!-- Icône notifications -->
		<a href="#" class="relative p-2 hover:bg-brand-light/30 transition text-brand-dark" aria-label="Notifications">
			<span class="material-icons text-xl">notifications</span>
		</a>

		<!-- Menu utilisateur -->
		{% set firstName = app.user ? app.user.email|split('@')[0]|capitalize : 'Visiteur' %}
		{% set userRole = app.user ? (app.user.roles|first|replace({'ROLE_': ''})|lower|capitalize) : 'Guest' %}

		<div class="relative" x-data="{ open: false }">
			<button @click="open = !open" class="flex items-center gap-3 rounded-full border border-gray-200 px-3 py-1.5
					                     bg-bg-card hover:bg-gray-50 transition cursor-pointer shadow-sm">
				<img src="https://ui-avatars.com/api/?name={{ firstName }}&background=0077B6&color=fff" alt="Avatar" class="w-8 h-8 rounded-full border border-gray-200 shadow-sm">
				<div class="text-left pr-1 hidden md:block">
					<p class="text-xs font-bold text-brand-dark">{{ firstName }}</p>
					<p class="text-[10px] text-gray-500 uppercase tracking-wide">{{ userRole }}</p>
				</div>
				<span class="material-icons text-sm text-gray-400">expand_more</span>
			</button>

			<!-- Dropdown -->
			<div x-show="open" @click.away="open = false" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 scale-95" x-transition:enter-end="opacity-100 scale-100" x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100 scale-100" x-transition:leave-end="opacity-0 scale-95" class="absolute right-0 mt-2 w-48 bg-bg-card rounded-xl shadow-xl border border-gray-100 z-50 py-2">

				<!-- Toggle Dark/Light -->
				<button id="darkModeToggle" class="flex items-center w-full px-4 py-2 text-sm text-gray-700 hover:bg-brand-light/20 hover:text-brand-primary transition">
					<span class="material-icons text-base mr-3 opacity-70">dark_mode</span>
					Dark/Light
				</button>

				<!-- Préférences -->
				<a href="#" class="flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-brand-light/20 hover:text-brand-primary transition">
					<span class="material-icons text-base mr-3 opacity-70">tune</span>
					Préférences
				</a>

				<!-- Documentation -->
				<a href="#" class="flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-brand-light/20 hover:text-brand-primary transition">
					<span class="material-icons text-base mr-3 opacity-70">help_outline</span>
					Documentation
				</a>

				<!-- Profil (ajouté ici) -->
				<a href="{{ path('profile_read', {'id': app.user.id}) }}" class="flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-brand-light/20 hover:text-brand-primary transition">
					<span class="material-icons text-base mr-3 opacity-70">account_circle</span>
					Profil
				</a>

				<hr class="my-1 border-gray-100">

				<a href="{{ path('logout') }}" class="flex items-center px-4 py-2 text-sm text-danger hover:bg-red-50 transition">
					<span class="material-icons text-base mr-3 opacity-70">logout</span>
					Déconnexion
				</a>
			</div>
		</div>
	</div>
</header>

