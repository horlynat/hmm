<header
	class="flex justify-between items-center bg-white/80 backdrop-blur-md px-4 md:px-6 py-3 border-b border-gray-200 sticky top-0 z-40">

	<!-- Zone gauche : Déclencheur Mobile + Fil d’Ariane -->
	<div
		class="flex items-center space-x-3 md:space-x-6 min-w-0">
		<!-- 🍔 BOUTON HAMBURGER (Visible uniquement sur Mobile/Tablette) -->
		<button @click="mobileSidebarOpen = true" class="md:hidden p-2 rounded-xl text-gray-600 hover:bg-gray-100 transition-colors focus:outline-none" aria-label="Ouvrir le menu">
			<span class="material-icons text-2xl flex items-center">menu</span>
		</button>

		<!-- Fil d’Ariane (Masqué sur très petits écrans si débordement, scroll horizontal fluide) -->
		<nav class="flex items-center text-xs md:text-sm text-gray-500 overflow-x-auto whitespace-nowrap scrollbar-none py-1">
			<a href="{{ path('admin_dashboard_index') }}" class="flex items-center text-(--brand-primary) font-bold hover:text-brand-accent transition">
				<span class="material-icons text-base mr-1">home</span>
				Home
			</a>

			{% set segments = app.request.pathInfo|trim('/')|split('/') %}
			{% for segment in segments %}
				<span class="mx-1.5 text-gray-300">/</span>
				<span class="capitalize text-(--brand-dark) font-medium truncate max-w-[100px] md:max-w-none">
					{{ segment|replace({'_': ' '}) }}
				</span>
			{% endfor %}
		</nav>
	</div>

	<!-- Zone droite : Recherche + Utilitaires -->
	<div
		class="flex items-center space-x-2 md:space-x-4 shrink-0">

		<!-- Barre de recherche (Masquée sur smartphone, activée à partir du breakpoint SM) -->
		<div class="relative hidden sm:block">
			<input type="text" placeholder="Rechercher..." class="input input-search w-48 lg:w-72 shadow-sm text-sm py-1.5 focus:ring-2 focus:ring-brand-primary"/>
		</div>

		<!-- Icône Notifications (épurée) -->
		<a href="#" class="relative p-2 rounded-xl hover:bg-gray-100 transition text-gray-600" aria-label="Notifications">
			<span class="material-icons text-xl flex items-center">notifications</span>
			<span class="absolute top-2 right-2 w-2 h-2 bg-red-500 rounded-full"></span>
		</a>

		<!-- Menu utilisateur -->
		{% set firstName = app.user ? app.user.email|split('@')[0]|capitalize : 'Visiteur' %}
		{% set userRole = app.user ? (app.user.roles|first|replace({'ROLE_': ''})|lower|capitalize) : 'Guest' %}

		<div class="relative" x-data="{ open: false }">
			<button @click="open = !open" class="flex items-center gap-2 rounded-full border border-gray-200 p-1 md:px-3 md:py-1.5
										                     bg-white hover:bg-gray-50 transition cursor-pointer shadow-sm">
				<img src="https://ui-avatars.com/api/?name={{ firstName }}&background=0077B6&color=fff" alt="Avatar" class="w-7 h-7 md:w-8 md:h-8 rounded-full shadow-inner">
				<div class="text-left pr-1 hidden md:block select-none">
					<p class="text-xs font-bold text-(--brand-dark) leading-tight">{{ firstName }}</p>
					<p class="text-[9px] text-gray-400 uppercase tracking-wide font-medium">{{ userRole }}</p>
				</div>
				<span class="material-icons text-sm text-gray-400 hidden md:block">expand_more</span>
			</button>

			<!-- Dropdown Aligné à droite -->
			<div x-show="open" @click.away="open = false" x-transition:enter="transition ease-out duration-150" x-transition:enter-start="opacity-0 scale-95 transform -translate-y-2" x-transition:enter-end="opacity-100 scale-100 transform translate-y-0" x-transition:leave="transition ease-in duration-100" x-transition:leave-start="opacity-100 scale-100" x-transition:leave-end="opacity-0 scale-95" class="absolute right-0 mt-2 w-52 bg-white rounded-xl shadow-xl border border-gray-100 z-50 py-1.5 text-sm" style="display: none;">
				<a href="{{ path('profile_read', {'id': app.user.id|default(1)}) }}" class="flex items-center px-4 py-2 text-gray-700 hover:bg-gray-50 transition">
					<span class="material-icons text-base mr-3 text-gray-400">account_circle</span>Profil
				</a>
				<a href="#" class="flex items-center px-4 py-2 text-gray-700 hover:bg-gray-50 transition">
					<span class="material-icons text-base mr-3 text-gray-400">tune</span>Préférences
				</a>
				<a href="#" class="flex items-center px-4 py-2 text-gray-700 hover:bg-gray-50 transition">
					<span class="material-icons text-base mr-3 text-gray-400">help_outline</span>Aide
				</a>
				<hr class="my-1.5 border-gray-100">
				<a href="{{ path('logout') }}" class="flex items-center px-4 py-2 text-red-600 hover:bg-red-50 transition font-medium">
					<span class="material-icons text-base mr-3 opacity-80">logout</span>Déconnexion
				</a>
			</div>
		</div>
	</div>
</header>
