{# Paramètre attendu : `separatorLabel` (ex: "Ou continuez avec"). #}
{# Google/GitHub ne sont pas encore intégrés côté serveur (pas de bundle OAuth) :
   les boutons sont visuellement désactivés plutôt que des liens morts "#"
   qui laissaient croire à une fonctionnalité active qui ne fait rien. #}
<div class="mt-10">
	<div class="relative">
		<div class="absolute inset-0 flex items-center">
			<div class="w-full border-t border-gray-300"></div>
		</div>
		<div class="relative flex justify-center text-sm">
			<span class="bg-white px-2 text-gray-500">{{ separatorLabel }}</span>
		</div>
	</div>

	<div class="mt-6 grid grid-cols-2 gap-4">
		<!-- Google (bientôt disponible) -->
