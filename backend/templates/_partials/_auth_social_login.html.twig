			class="flex justify-center items-center gap-2 rounded-full border border-gray-200 bg-gray-50 p-3 text-gray-400 cursor-not-allowed select-none"
			role="button" aria-disabled="true" tabindex="-1" title="Connexion Google — bientôt disponible">
			<svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 48 48" class="h-6 w-6 opacity-40">
				<path fill="#EA4335" d="M24 9.5c3.94 0 6.58 1.7 8.1 3.13l5.9-5.9C34.5 3.5 29.7 1.5 24 1.5 14.5 1.5 6.5 7.5 3.5 15.5l7.4 5.7C12.5 14.5 17.7 9.5 24 9.5z"/>
