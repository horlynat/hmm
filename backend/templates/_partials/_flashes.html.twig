{% for label, messages in app.flashes %}
	{% for message in messages %}
		<div
			class="alert alert-{{ label }} flex items-center mb-4 transition-all duration-300">

			<!-- Icône -->
			{% set icons = {
          'success': 'check_circle',
          'danger':  'dangerous',
          'error':   'error',
          'warning': 'warning',
          'info':    'info'
      } %}
			<span class="material-icons mr-3 text-xl opacity-80">
				{{ icons[label] ?? icons['info'] }}
			</span>

			<!-- Message -->
			<span class="text-sm font-medium flex-1">{{ message }}</span>

			<!-- Bouton de fermeture -->
			<button onclick="this.parentElement.remove();" class="ml-4 opacity-60 hover:opacity-100 transition-opacity">
				<span class="material-icons text-lg">close</span>
			</button>
		</div>
	{% endfor %}
{% endfor %}

