{% extends 'base.html.twig' %}

{% block title %}Détails :
	{{ article.title }}
{% endblock %}

{% block body %}
	<main class="p-8 bg-gray-50 min-h-screen">

		<div class="flex justify-between items-center mb-8">
			<h1 class="text-2xl font-bold text-gray-800 flex items-center space-x-2">
				<span class="material-icons text-blue-600">description</span>
				<span>Détails de l'article</span>
			</h1>
			<a href="{{ path('article_index') }}" class="px-5 py-2 bg-gray-200 text-gray-700 rounded-lg shadow hover:bg-gray-300 transition flex items-center space-x-2">
				<span class="material-icons">arrow_back</span>
				<span>Retour à la liste</span>
			</a>
		</div>

		<div class="bg-white p-8 rounded-xl shadow-lg border border-gray-100 space-y-6">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				<div>
					<p class="text-sm text-gray-500">Slug (URL)</p>
					<p class="text-sm font-mono text-blue-600 bg-blue-50 p-1 rounded">{{ article.slug }}</p>
				</div>
				<div>
					<p class="text-sm text-gray-500">Titre</p>
					<p class="text-lg font-semibold text-gray-800">{{ article.title }}</p>
				</div>
				<div class="md:col-span-2">
					<p class="text-sm text-gray-500">Contenu</p>
					<p class="text-gray-700 mt-2 leading-relaxed">{{ article.content }}</p>
				</div>
				<div>
					<p class="text-sm text-gray-500">Publié le</p>
					<p class="text-lg font-semibold text-gray-800">
						{{ article.publishedAt ? article.publishedAt|date('d/m/Y H:i') : '—' }}
					</p>
				</div>
				<div>
					<p class="text-sm text-gray-500">Statut</p>
					{% if article.publishedAt %}
						<span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-sm font-semibold">Publié</span>
					{% else %}
						<span class="px-3 py-1 bg-yellow-100 text-yellow-700 rounded-full text-sm font-semibold">Brouillon</span>
					{% endif %}
				</div>
			</div>

			<div>
				<p class="text-sm text-gray-500 mb-2">Tags associés</p>
				<div class="flex flex-wrap gap-2">
					{% for tag in article.tags %}
						<span class="px-3 py-1 bg-indigo-100 text-indigo-700 rounded-full text-sm font-semibold">
							{{ tag.name }}
						</span>
					{% else %}
						<span class="text-gray-400 text-sm">Aucun tag associé</span>
					{% endfor %}
				</div>
			</div>
		</div>

		<div class="flex space-x-4 mt-6">
			<a href="{{ path('article_update', {'slug': article.slug}) }}" class="px-5 py-2 bg-yellow-100 text-yellow-700 rounded-lg shadow hover:bg-yellow-200 transition flex items-center space-x-2">
				<span class="material-icons">edit</span>
				<span>Modifier</span>
			</a>

			{{ include('article/_delete_form.html.twig', {'article': article}) }}
		</div>
	</main>
{% endblock %}
