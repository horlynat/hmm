<form
	method="post" action="{{ path('article_delete', {'slug': article.slug}) }}" onsubmit="return confirm('Voulez-vous vraiment supprimer cet article ? Cette action est irréversible.');" class="inline-block">

	{# On garde l'ID pour le token car il est immuable, même si le slug change #}
	<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ article.id) }}">

	<button type="submit" onclick="this.disabled=true; this.form.submit();" class="group flex items-center space-x-2 px-4 py-2 bg-white border border-red-200 text-red-600 rounded-lg shadow-sm hover:bg-red-50 hover:border-red-300 transition-all duration-200">
		<span class="material-icons text-lg group-hover:scale-110 transition-transform">delete_forever</span>
		<span class="font-medium text-sm">Supprimer</span>
	</button>
</form>
