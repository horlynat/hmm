<!-- Formulaire premium compact -->
<div class="bg-white p-6 rounded-lg shadow-md border border-gray-100">
	{{ form_start(form, {'attr': {'class': 'space-y-4'}}) }}

	<!-- Champ Nom de la catégorie -->
	<div>
		<label class="block text-sm font-medium text-gray-700 mb-1">Nom de la catégorie</label>
		{{ form_widget(form.name, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-orange-600 focus:outline-none'}}) }}
		{% if form_errors(form.name) %}
			<p class="text-red-600 text-xs mt-1">{{ form_errors(form.name) }}</p>
		{% endif %}
	</div>

	<!-- Bouton CTA -->
	<div class="flex justify-end">
		<button class="px-5 py-2 bg-gradient-to-r from-orange-600 to-red-600 text-white rounded-md shadow hover:scale-105 transform transition flex items-center space-x-2">
			<span class="material-icons text-sm">save</span>
			<span>{{ button_label|default('Enregistrer') }}</span>
		</button>
	</div>

	{{ form_end(form) }}
</div>