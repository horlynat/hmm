{% extends 'base.html.twig' %}

{% block title %}Gestion des Tags{% endblock %}

{% block body %}
<main class="p-8 bg-gray-50 min-h-screen">

    <!-- Header -->
    <div class="flex justify-between items-center mb-8">
        <h1 class="text-2xl font-bold text-gray-800 flex items-center space-x-2">
            <span class="material-icons text-purple-600">label</span>
            <span>Gestion des Tags</span>
        </h1>
        <a href="{{ path('tag_create') }}"
           class="px-5 py-2 bg-gradient-to-r from-purple-600 to-indigo-600 text-white rounded-lg shadow hover:scale-105 transform transition flex items-center space-x-2">
            <span class="material-icons">add_circle</span>
            <span>Créer un nouveau Tag</span>
        </a>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-xl shadow overflow-hidden">
        <table class="min-w-full text-left">
            <thead class="bg-gray-100 text-gray-600 uppercase text-sm sticky top-0">
                <tr>
                    <th class="px-6 py-3">Id</th>
                    <th class="px-6 py-3">Nom</th>
                    <th class="px-6 py-3">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                {% for tag in tags %}
                    <tr class="hover:bg-gray-50 transition">
                        <td class="px-6 py-4 text-gray-700">{{ tag.id }}</td>
                        <td class="px-6 py-4 font-semibold text-gray-800">
                            <span class="px-3 py-1 bg-indigo-100 text-indigo-700 rounded-full text-sm font-semibold">
                                {{ tag.name }}
                            </span>
                        </td>
                        <td class="px-6 py-4 flex space-x-3">
                            <a href="{{ path('tag_read', {'id': tag.id}) }}"
                               class="px-3 py-1 bg-blue-100 text-blue-700 rounded-lg hover:bg-blue-200 transition flex items-center space-x-1 text-sm">
                                <span class="material-icons text-sm">visibility</span>
                                <span>Détails</span>
                            </a>
                            <a href="{{ path('tag_update', {'id': tag.id}) }}"
                               class="px-3 py-1 bg-yellow-100 text-yellow-700 rounded-lg hover:bg-yellow-200 transition flex items-center space-x-1 text-sm">
                                <span class="material-icons text-sm">edit</span>
                                <span>Modifier</span>
                            </a>
                            <a href="{{ path('tag_delete', {'id': tag.id}) }}"
                               class="px-3 py-1 bg-red-100 text-red-700 rounded-lg hover:bg-red-200 transition flex items-center space-x-1 text-sm">
                                <span class="material-icons text-sm">delete</span>
                                <span>Supprimer</span>
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3" class="px-6 py-12 text-center">
                            <div class="flex flex-col items-center space-y-3">
                                <span class="material-icons text-gray-400 text-5xl">inbox</span>
                                <p class="text-gray-500">Aucun tag trouvé</p>
                                <a href="{{ path('tag_create') }}"
                                   class="px-4 py-2 bg-purple-600 text-white rounded-lg shadow hover:bg-purple-700 transition">
                                    Créer un Tag
                                </a>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="flex justify-center items-center mt-6 space-x-2">
        <a href="#" class="px-3 py-1 rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition">&laquo;</a>
        <a href="#" class="px-3 py-1 rounded-lg bg-purple-600 text-white shadow">1</a>
        <a href="#" class="px-3 py-1 rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition">2</a>
        <a href="#" class="px-3 py-1 rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition">3</a>
        <a href="#" class="px-3 py-1 rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition">&raquo;</a>
    </div>
</main>
{% endblock %}
