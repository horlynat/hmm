<!-- Formulaire premium compact -->
<div class="bg-white p-6 rounded-lg shadow-md border border-gray-100">
	{{ form_start(form, {'attr': {'class': 'space-y-4'}}) }}

	{% for field in form %}
		<div>
			<label class="block text-sm font-medium text-gray-700 mb-1">
				{{ field.vars.label|default(field.vars.name|capitalize) }}
			</label>
			{{ form_widget(field, {'attr': {
                    'class': 'w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-indigo-600 focus:outline-none'
                }}) }}
			{% if form_errors(field) %}
				<p class="text-red-600 text-xs mt-1">{{ form_errors(field) }}</p>
			{% endif %}
		</div>
	{% endfor %}

	<!-- Bouton CTA -->
	<div class="flex justify-end">
		<button class="px-5 py-2 bg-gradient-to-r from-indigo-600 to-purple-600 text-white rounded-md shadow hover:scale-105 transform transition flex items-center space-x-2">
			<span class="material-icons text-sm">save</span>
			<span>{{ button_label|default('Enregistrer') }}</span>
		</button>
	</div>

	{{ form_end(form) }}
</div>