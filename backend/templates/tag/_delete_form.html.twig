<form method="post" 
      action="{{ path('tag_delete', {'id': tag.id}) }}" 
      onsubmit="return confirm('Voulez-vous vraiment supprimer ce tag ?');"
      class="inline-block">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tag.id) }}">
    <button class="px-5 py-2 bg-gradient-to-r from-red-600 to-red-700 text-white rounded-lg shadow hover:scale-105 transform transition flex items-center space-x-2">
        <span class="material-icons">delete_forever</span>
        <span>Supprimer</span>
    </button>
</form>
