{# templates/admin/skill_category/_form.html.twig #}
{{ form_start(form, {'attr': {'class': 'space-y-6', 'novalidate': 'novalidate'}}) }}

<div class="card max-w-2xl">
	<div>
		{{ form_label(form.name, 'Nom de la catégorie', {'label_attr': {'class': 'block text-sm font-bold mb-2 text-brand-dark'}}) }}
		{{ form_widget(form.name, {'attr': {'class': 'input w-full', 'placeholder': 'Ex: Front-end, Backend, Design...'}}) }}
		{{ form_errors(form.name, {'attr': {'class': 'text-danger text-xs mt-1'}}) }}
	</div>

	<div class="flex justify-end pt-4">
		<button type="submit" class="btn btn-primary gap-2">
			<span class="material-icons text-sm">save</span>
			<span>{{ button_label|default('Enregistrer') }}</span>
		</button>
	</div>
</div>

{{ form_end(form) }}
