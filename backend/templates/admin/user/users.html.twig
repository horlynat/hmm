{% extends 'base.html.twig' %}

{% block title %}Liste des Utilisateurs
{% endblock %}

{% block body %}
	<div
		class="container mx-auto px-4 py-8">
		<!-- Titre -->
		<div class="flex justify-between items-center mb-6">
			<h1 class="text-3xl font-bold">Liste des Utilisateurs</h1>
		</div>

		<!-- Filtres -->
		<div class="bg-white rounded-lg shadow p-6 mb-8">
			<form
				method="get" class="grid grid-cols-1 md:grid-cols-3 gap-4">
				<!-- Recherche -->
				<div class="md:col-span-2">
					<label for="search" class="block text-sm font-medium text-gray-700">Recherche</label>
					<input type="text" id="search" name="search" value="{{ filters.search ?? '' }}" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" placeholder="Email, nom complet...">
				</div>

				<!-- Boutons -->
				<div class="flex items-end space-x-2">
					<button type="submit" class="btn btn-secondary w-full">
						🔍 Filtrer
					</button>
					<a href="{{ path('admin_dashboard_users') }}" class="btn btn-outline w-full">
						❌ Réinitialiser
					</a>
				</div>
			</form>
		</div>

		<!-- Tableau des utilisateurs -->
		<div class="bg-white rounded-lg shadow overflow-hidden">
			<table class="min-w-full divide-y divide-gray-200">
				<thead class="bg-gray-50">
					<tr>
						<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
							Photo
						</th>
						<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider cursor-pointer hover:bg-gray-100">
							<a href="{{ path('admin_dashboard_users', filters|merge({'sort': 'fullName', 'direction': (filters.direction == 'asc' ? 'desc' : 'asc'), 'page': 1})) }}">
								Nom
								{% if filters.sort == 'fullName' %}
									{% if filters.direction == 'asc' %}↑{% else %}↓
									{% endif %}
								{% endif %}
							</a>
						</th>
						<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider cursor-pointer hover:bg-gray-100">
							<a href="{{ path('admin_dashboard_users', filters|merge({'sort': 'email', 'direction': (filters.direction == 'asc' ? 'desc' : 'asc'), 'page': 1})) }}">
								Email
								{% if filters.sort == 'email' %}
									{% if filters.direction == 'asc' %}↑{% else %}↓
									{% endif %}
								{% endif %}
							</a>
						</th>
						<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
							Rôle
						</th>
						<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
							Projets
						</th>
						<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider cursor-pointer hover:bg-gray-100">
							<a href="{{ path('admin_dashboard_users', filters|merge({'sort': 'createdAt', 'direction': (filters.direction == 'asc' ? 'desc' : 'asc'), 'page': 1})) }}">
								Inscrit le
								{% if filters.sort == 'createdAt' %}
									{% if filters.direction == 'asc' %}↑{% else %}↓
									{% endif %}
								{% endif %}
							</a>
						</th>
						<th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
							Actions
						</th>
					</tr>
				</thead>
				<tbody class="bg-white divide-y divide-gray-200">
					{% for user in users %}
						<tr>
							<!-- Photo -->
							<td class="px-6 py-4 whitespace-nowrap">
								<img class="h-10 w-10 rounded-full" src="{{ (user.profileImage ?? 'https://ui-avatars.com/api/?name=' ~ user.fullName|url_encode) }}" alt="{{ user.fullName ?? user.email }}">
							</td>

							<!-- Nom -->
							<td class="px-6 py-4 whitespace-nowrap">
								<div class="text-sm font-medium text-gray-900">
									{{ user.fullName ?? 'Non spécifié' }}
								</div>
							</td>

							<!-- Email -->
							<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
								{{ user.email }}
							</td>

							<!-- Rôle -->
							<td class="px-6 py-4 whitespace-nowrap">
								<span class="px-2 py-1 rounded-full text-xs font-semibold bg-blue-500 text-white">
									{{ user.roles|first|replace({'ROLE_': ''})|capitalize }}
								</span>
							</td>

							<!-- Projets -->
							<td class="px-6 py-4 whitespace-nowrap">
								<div class="text-sm font-medium">
									{{ user.ownedProjects|length }}
									propres
								</div>
								<div class="text-xs text-gray-500">
									{{ user.collaboratingProjects|length }}
									collaborations
								</div>
							</td>

							<!-- Date d'inscription -->
							<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
								{{ user.createdAt|date('d/m/Y H:i') }}
							</td>

							<!-- Actions -->
							<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-right">
								<a href="{{ path('app_user_show', {'id': user.id}) }}" class="text-blue-600 hover:text-blue-900 mr-2">
									👁️ Voir
								</a>
								<a href="{{ path('app_user_edit', {'id': user.id}) }}" class="text-blue-600 hover:text-blue-900 mr-2">
									✏️ Modifier
								</a>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="7" class="px-6 py-4 text-center text-gray-500">
								Aucun utilisateur trouvé.
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>

		<!-- Pagination -->
		{% if users|length > 0 %}
			<div class="mt-6 flex justify-center">
				<nav class="flex items-center space-x-2" aria-label="Pagination">
					{% if page > 1 %}
						<a href="{{ path('admin_user_index', filters|merge({'page': page - 1})) }}" class="px-3 py-1 rounded-md border border-gray-300 text-gray-700 hover:bg-gray-50">
							← Précédent
						</a>
					{% endif %}

					{% for p in range(1, totalPages + 1) %}
						<a href="{{ path('admin_user_index', filters|merge({'page': p})) }}" class="px-3 py-1 rounded-md {% if p == page %}bg-blue-500 text-white{% else %}border border-gray-300 text-gray-700 hover:bg-gray-50{% endif %}">
							{{ p }}
						</a>
					{% endfor %}

					{% if page < totalPages %}
						<a href="{{ path('admin_user_index', filters|merge({'page': page + 1})) }}" class="px-3 py-1 rounded-md border border-gray-300 text-gray-700 hover:bg-gray-50">
							Suivant →
						</a>
					{% endif %}
				</nav>
			</div>
		{% endif %}
	</div>
{% endblock %}
