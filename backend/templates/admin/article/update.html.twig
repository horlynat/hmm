{# templates/admin/article/update.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Modifier l'article :
	{{ article.title }}
{% endblock %}

{% block body %}
	<main class="container mx-auto px-4 py-8">

		<div class="mb-6">
			<a href="{{ path('admin_article_index') }}" class="inline-flex items-center gap-2 text-sm font-semibold opacity-60 hover:text-brand-primary transition">
				<i class="ti ti-arrow-left"></i>
				<span>Retour à la liste</span>
			</a>
		</div>

		<!-- Titre de section -->
		<div class="mb-8">
			<h1 class="text-2xl font-bold tracking-tight flex items-center gap-2">
				<i class="ti ti-edit text-brand-primary"></i>
				<span>Modifier l'article</span>
			</h1>
			<p class="text-sm opacity-60 mt-1">Modifiez le contenu, ajustez la couverture ou gérez les tags de l'article.</p>
		</div>

		{{ include('admin/article/_form.html.twig', {'button_label': 'Enregistrer les modifications'}) }}

	</main>
{% endblock %}
