{# templates/admin/config/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Configuration système
{% endblock %}

{% block body %}
	<main class="container mx-auto px-4 py-8">

		<!-- 📑 EN-TÊTE -->
		<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
			<div>
				<h1 class="text-3xl font-heading font-bold flex items-center gap-2 text-brand-dark">
					<span class="material-icons text-brand-primary">tune</span>
					<span>Configuration système</span>
				</h1>
				<p class="text-sm opacity-60 mt-1">Branding, thème et langues du back-office.</p>
			</div>
		</div>

		{{ form_start(form, {'attr': {'class': 'space-y-6', 'novalidate': 'novalidate'}}) }}
		<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">

			<div class="lg:col-span-2 space-y-6 card">
				<div>
					{{ form_label(form.siteName, 'Nom du site', {'label_attr': {'class': 'block text-sm font-bold mb-2 text-brand-dark'}}) }}
					{{ form_widget(form.siteName, {'attr': {'class': 'input w-full'}}) }}
					{{ form_errors(form.siteName, {'attr': {'class': 'text-danger text-xs mt-1'}}) }}
				</div>

				<div>
					<span class="block text-sm font-bold mb-2 text-brand-dark">Logo actuel</span>
					{% if settings.logoPath %}
						<img src="{{ settings.logoPath }}" alt="Logo" class="h-16 rounded-sm border border-gray-200 mb-3">
					{% else %}
						<p class="text-xs opacity-50 mb-3">Aucun logo défini.</p>
					{% endif %}
					{{ form_label(form.logoFile, null, {'label_attr': {'class': 'block text-sm font-bold mb-2 text-brand-dark'}}) }}
					{{ form_widget(form.logoFile, {'attr': {'class': 'input w-full'}}) }}
					{{ form_errors(form.logoFile, {'attr': {'class': 'text-danger text-xs mt-1'}}) }}
				</div>

				<div>
					{{ form_label(form.primaryColor, 'Couleur principale', {'label_attr': {'class': 'block text-sm font-bold mb-2 text-brand-dark'}}) }}
					{{ form_widget(form.primaryColor, {'attr': {'class': 'input h-10 w-24'}}) }}
					{{ form_errors(form.primaryColor, {'attr': {'class': 'text-danger text-xs mt-1'}}) }}
				</div>

				<div>
					{{ form_label(form.theme, 'Thème', {'label_attr': {'class': 'block text-sm font-bold mb-2 text-brand-dark'}}) }}
					{{ form_widget(form.theme, {'attr': {'class': 'input w-full'}}) }}
					{{ form_errors(form.theme, {'attr': {'class': 'text-danger text-xs mt-1'}}) }}
				</div>

				<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
					<div>
						{{ form_label(form.defaultLocale, 'Langue par défaut', {'label_attr': {'class': 'block text-sm font-bold mb-2 text-brand-dark'}}) }}
						{{ form_widget(form.defaultLocale, {'attr': {'class': 'input w-full'}}) }}
						{{ form_errors(form.defaultLocale, {'attr': {'class': 'text-danger text-xs mt-1'}}) }}
					</div>
					<div>
						{{ form_label(form.availableLocales, 'Langues disponibles', {'label_attr': {'class': 'block text-sm font-bold mb-2 text-brand-dark'}}) }}
						{{ form_widget(form.availableLocales) }}
						{{ form_errors(form.availableLocales, {'attr': {'class': 'text-danger text-xs mt-1'}}) }}
					</div>
				</div>
			</div>

			<div class="space-y-6">
				<div class="card space-y-4">
					<h3 class="text-xs font-bold uppercase tracking-wider opacity-40 border-b border-gray-100 pb-2 flex items-center gap-2">
						<span class="material-icons text-sm">bolt</span>
						Actions
					</h3>

					{% if settings.updatedAt %}
						<p class="text-xs opacity-60">
							Dernière mise à jour le {{ settings.updatedAt|date('d/m/Y à H:i') }}
							{% if settings.updatedBy %}par {{ settings.updatedBy.fullName ?? settings.updatedBy.email }}{% endif %}
						</p>
					{% endif %}

					<div class="pt-2">
						<button type="submit" class="btn btn-primary w-full gap-2">
							<span class="material-icons text-sm">save</span>
							<span>Enregistrer</span>
						</button>
					</div>
				</div>
			</div>
		</div>
		{{ form_end(form) }}

	</main>
{% endblock %}
