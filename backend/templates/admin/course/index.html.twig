{# templates/admin/course/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Gestion des Formations
{% endblock %}

{% block body %}
	<main
		class="container mx-auto px-4 py-8">

		<!-- 📑 EN-TÊTE -->
		<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
			<div>
				<h1 class="text-3xl font-heading font-bold flex items-center gap-2 text-brand-dark">
					<span class="material-icons text-brand-primary">school</span>
					<span>Gestion des Formations</span>
				</h1>
				<p class="text-sm opacity-60 mt-1">Gérez vos diplômes, certifications et parcours académiques.</p>
			</div>
			<a href="{{ path('admin_course_create') }}" class="btn btn-primary gap-2">
				<span class="material-icons text-sm">add_circle</span>
				<span>Ajouter une formation</span>
			</a>
		</div>

		<!-- 📊 TABLEAU (Sans les messages flash gérés par base.html.twig) -->
		<div class="soft-card">
			<table class="table">
				<thead>
					<tr>
						<th class="w-16">Id</th>
						<th>Formation & Institution</th>
						<th class="w-48">Période</th>
						<th class="w-40 text-right">Actions</th>
					</tr>
				</thead>
				<tbody>
					{% for course in courses %}
						<tr>
							<td class="font-mono text-xs opacity-50">{{ course.id }}</td>
							<td>
								<div class="font-bold text-base truncate text-brand-dark">{{ course.title }}</div>
								<div class="text-xs opacity-70 flex items-center gap-1 mt-0.5">
									<span class="material-icons text-[14px]">account_balance</span>
									{{ course.institution }}
								</div>
							</td>
							<td class="text-xs opacity-80">
								<div class="flex flex-col gap-0.5">
									<span>Du :
										{{ course.startDate ? course.startDate|date('d/m/Y') : '—' }}</span>
									<span>Au :
										{{ course.endDate ? course.endDate|date('d/m/Y') : '—' }}</span>
								</div>
							</td>
							<td>
								<div class="flex items-center justify-end gap-2">
									<a href="{{ path('admin_course_read', {'id': course.id}) }}" class="p-2 hover:bg-brand-light rounded-sm transition-colors text-brand-dark" title="Voir">
										<span class="material-icons text-lg block">visibility</span>
									</a>
									<a href="{{ path('admin_course_update', {'id': course.id}) }}" class="p-2 hover:bg-warning/20 rounded-sm transition-colors text-warning" title="Modifier">
										<span class="material-icons text-lg block">edit</span>
									</a>
									{{ include('admin/course/_delete_form.html.twig', {'course': course}) }}
								</div>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="4" class="text-center py-12 opacity-40">
								<span class="material-icons text-4xl block mb-2">school</span>
								<span>Aucune formation trouvée pour le moment.</span>
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>
	</main>
{% endblock %}
