{# templates/admin/testimonial/_publish_form.html.twig #}
{% if testimonial.isPublished %}
	<form method="post" action="{{ path('admin_testimonial_unpublish', {'id': testimonial.id}) }}" class="w-full">
		<input type="hidden" name="_token" value="{{ csrf_token('testimonial_publish_' ~ testimonial.id) }}">
		<button type="submit" class="btn btn-secondary w-full text-sm gap-2">
			<span class="material-icons text-sm">visibility_off</span>
			<span>Dépublier</span>
		</button>
	</form>
{% else %}
	<form method="post" action="{{ path('admin_testimonial_publish', {'id': testimonial.id}) }}" class="w-full">
		<input type="hidden" name="_token" value="{{ csrf_token('testimonial_publish_' ~ testimonial.id) }}">
		<button type="submit" class="btn w-full text-sm gap-2 bg-green-500 text-white border-0">
			<span class="material-icons text-sm">publish</span>
			<span>Publier</span>
		</button>
	</form>
{% endif %}
