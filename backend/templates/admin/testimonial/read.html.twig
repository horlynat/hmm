{# templates/admin/testimonial/read.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Témoignage :
	{{ testimonial.author }}
{% endblock %}

{% block body %}
	<main class="container mx-auto px-4 py-8">

		<div class="mb-6">
			<a href="{{ path('admin_testimonial_index') }}" class="btn btn-secondary gap-2 px-3 py-2 text-sm w-fit">
				<span class="material-icons text-base">arrow_back</span>
				<span>Retour à la liste des témoignages</span>
			</a>
		</div>

		<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">

			<!-- 📖 CONTENU (70%) -->
			<div class="lg:col-span-2 card space-y-6">
				<div>
					{% if testimonial.isPublished %}
						<span class="badge bg-green-500 text-white">Publié le {{ testimonial.publishedAt|date('d/m/Y H:i') }}</span>
					{% else %}
						<span class="badge bg-yellow-500 text-black">En attente de publication</span>
					{% endif %}
					<h1 class="text-3xl font-heading font-bold tracking-tight mt-3 text-brand-dark">
						{{ testimonial.author }}
					</h1>
					{% if testimonial.rating %}
						<p class="text-sm opacity-60 mt-1">{{ testimonial.rating }} ★</p>
					{% endif %}
				</div>

				<div class="leading-relaxed text-base space-y-4 whitespace-pre-line border-t border-gray-100 pt-6 text-brand-dark/80">
					{{ testimonial.content }}
				</div>

				{% if testimonial.media|length > 0 %}
					<div class="border-t border-gray-100 pt-6">
						<h3 class="text-xs font-bold uppercase tracking-wider opacity-40 mb-3">Médias</h3>
						<div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
							{% for media in testimonial.media %}
								<div class="relative group">
									{% if media.type == 'image' %}
										<img src="{{ media.filePath }}" alt="{{ media.altText }}" class="rounded-sm w-full h-32 object-cover border border-gray-100">
									{% else %}
										<a href="{{ media.filePath }}" target="_blank" class="flex items-center justify-center h-32 rounded-sm border border-gray-100 bg-gray-50 text-brand-dark/60">
											<span class="material-icons text-3xl">description</span>
										</a>
									{% endif %}
									<form method="post" action="{{ path('admin_testimonial_delete_media', {'id': testimonial.id, 'mediaId': media.id}) }}" class="absolute top-1 right-1">
										<input type="hidden" name="_token" value="{{ csrf_token('admin_testimonial_delete_media_' ~ media.id) }}">
										<button type="submit" class="p-1 bg-white/90 hover:bg-danger hover:text-white rounded-full text-danger shadow" title="Supprimer ce média">
											<span class="material-icons text-sm block">close</span>
										</button>
									</form>
								</div>
							{% endfor %}
						</div>
					</div>
				{% endif %}
			</div>

			<!-- ⚙️ INFOS LATÉRALES (30%) -->
			<div class="space-y-6">
				<div class="card space-y-4">
					<h3 class="text-xs font-bold uppercase tracking-wider opacity-40 border-b border-gray-100 pb-2">
						Fiche Technique
					</h3>

					<div class="pt-2 flex flex-col gap-3">
						{% include 'admin/testimonial/_publish_form.html.twig' with {'testimonial': testimonial} %}
						<a href="{{ path('admin_testimonial_update', {'id': testimonial.id}) }}" class="btn btn-primary w-full text-sm gap-2">
							<span class="material-icons text-sm">edit</span>
							<span>Modifier le témoignage</span>
						</a>
						<div class="w-full [&>div]:w-full [&>div>form]:w-full text-center">
							{% include 'admin/testimonial/_delete_form.html.twig' with {'testimonial': testimonial} %}
						</div>
					</div>
				</div>
			</div>

		</div>
	</main>
{% endblock %}
