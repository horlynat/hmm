{# templates/admin/project/_form.html.twig #}
{{ form_start(form, {
    'attr': {'class': 'space-y-6', 'novalidate': 'novalidate'},
    'enctype': 'multipart/form-data'
}) }}

<div
	class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">

	<!-- 📄 COLONNE PRINCIPALE : ÉCRITURE -->
	<div class="lg:col-span-2 space-y-6 card">
		{# Utilisation de ta classe .card #}

		<!-- Champ Titre -->
			<div>{{ form_label(form.title, 'Titre du projet', {'label_attr': {'class': 'block text-sm font-bold mb-2'}}
			) }}{{ form_widget(form.title, {'attr': {'class': 'input w-full text-lg font-semibold', 'placeholder': 'Ex: Refonte de la plateforme e-commerce...'}}
			) }}{{ form_errors(form.title, {'attr': {'class': 'text-danger text-xs mt-1'}}
		) }}
		</div>

		<!-- Champ Description -->
			<div>{{ form_label(form.description, 'Description complète', {'label_attr': {'class': 'block text-sm font-bold mb-2'}}
			) }}{{ form_widget(form.description, {'attr': {'class': 'input textarea w-full h-[420px] text-base leading-relaxed', 'placeholder': 'Décrivez les objectifs, les livrables et le contexte...'}}
			) }}{{ form_errors(form.description, {'attr': {'class': 'text-danger text-xs mt-1'}}
		) }}
	</div>
	</div>

	<!-- ⚙️ COLONNE LATÉRALE : CONFIGURATION -->
		<div
		class="space-y-6"> <!-- Bloc Actions, Statut & Sauvegarde -->
		<div class="card space-y-4">
			<h3 class="text-xs font-bold uppercase tracking-wider opacity-40 border-b border-gray-100 pb-2 flex items-center gap-2">
				<span class="material-icons text-sm">bolt</span>
				Statut & Sauvegarde
			</h3>

			<div class="text-xs opacity-60 bg-brand-light/20 p-2.5 rounded-sm flex items-center gap-2">
				<span class="inline-block w-2 h-2 bg-warning rounded-full animate-pulse"></span>
				<span>Modifications locales prêtes</span>
			</div>

			{# Statut du projet (si configuré dans le formulaire projet) #}
			{% if form.status is defined %}
				<div>
					{{ form_label(form.status, 'Statut de départ', {'label_attr': {'class': 'block text-xs font-bold uppercase mb-2'}}) }}
					{{ form_widget(form.status, {'attr': {'class': 'input w-full text-xs'}}) }}
					{{ form_errors(form.status, {'attr': {'class': 'text-danger text-xs mt-1'}}) }}
				</div>
			{% endif %}

			<div class="pt-2 flex flex-col gap-2">
				<button type="submit" class="btn btn-primary w-full gap-2 cursor-pointer group">
					<span class="material-icons text-sm transition-transform group-hover:scale-110">save</span>
					<span>{{ button_label|default('Enregistrer le projet') }}</span>
				</button>
				{% if cancel_path is defined %}
					<a href="{{ cancel_path }}" class="w-full inline-flex justify-center items-center px-4 py-2.5 bg-white border border-gray-200 text-brand-dark/70 text-sm font-semibold rounded-xl hover:bg-gray-50 transition-all cursor-pointer">
						Annuler
					</a>
				{% endif %}
			</div>
		</div>

		<!-- Bloc Technologies / Skills -->
		<div class="card">
			<div class="flex items-center justify-between mb-2">
				{{ form_label(form.skills, 'Technologies utilisées', {'label_attr': {'class': 'block text-sm font-bold'}}) }}
			</div>

			{{ form_widget(form.skills, {'attr': {'class': 'input w-full text-sm'}}) }}
			<p class="text-[11px] opacity-40 mt-2 leading-normal">Maintenez
				<kbd class="bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded text-[10px]">Ctrl</kbd>
				pour faire plusieurs choix.</p>
			{{ form_errors(form.skills, {'attr': {'class': 'text-danger text-xs mt-1'}}) }}
		</div>

		<!-- Bloc Lien Externe (URL Démo/Prod) -->
		<div class="card">
			{{ form_label(form.link, 'Lien du projet', {'label_attr': {'class': 'block text-sm font-bold mb-2'}}) }}
			{{ form_widget(form.link, {'attr': {'class': 'input w-full text-sm', 'placeholder': 'https://monprojet.com'}}) }}
			{{ form_errors(form.link, {'attr': {'class': 'text-danger text-xs mt-1'}}) }}
		</div>

		<!-- Bloc Couverture / Média -->
		<div class="card">
			{{ form_label(form.media, 'Image de couverture', {'label_attr': {'class': 'block text-sm font-bold mb-2'}}) }}

			{% if project is defined and project.media is not empty %}
				{% set uploadedMedia = project.media|first %}
				<div class="mb-3 rounded-md overflow-hidden border border-gray-100 max-h-36 flex items-center justify-center group relative">
					<img src="{{ asset('uploads/projects/' ~ uploadedMedia.filePath) }}" alt="{{ uploadedMedia.altText|default('Couverture') }}" class="object-cover h-full w-full transition group-hover:scale-105">
				</div>
			{% endif %}

			{{ form_widget(form.media, {'attr': {'class': 'w-full text-xs opacity-70 file:mr-3 file:py-2 file:px-3 file:rounded-sm file:border-0 file:text-xs file:font-bold file:bg-brand-light file:text-brand-primary hover:file:opacity-80 cursor-pointer'}}) }}
			<p class="text-[11px] opacity-40 mt-2">Formats : JPG, PNG, PDF (Max : 5 Mo).</p>
			{{ form_errors(form.media, {'attr': {'class': 'text-danger text-xs mt-1'}}) }}
		</div>

	</div>
</div>
{{ form_end(form) }}
