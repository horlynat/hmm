{# templates/components/project/_expense_list.html.twig #}
<div
	class="space-y-4" {{ attributes }}>

	{# Flash messages d'actions asynchrones de Symfony UX #}
	{% for message in app.flashes('success') %}
		<div class="p-4 mb-4 text-sm text-green-800 rounded-lg bg-green-50 dark:bg-gray-800 dark:text-green-400" role="alert">
			{{ message }}
		</div>
	{% endfor %}

	{% if project.expenses is empty %}
		<div class="text-center py-10 border-2 border-dashed border-gray-200 rounded-xl bg-white/50">
			<span class="text-3xl block mb-2" role="img" aria-label="Portefeuille vide">💸</span>
			<p class="text-gray-500 font-medium mb-0">Aucune dépense enregistrée sur ce projet.</p>
			{% if not this.projectLocked %}
				<a href="{{ path('admin_project_add_expense', {id: project.id}) }}" class="btn btn-primary mt-4 inline-flex items-center gap-2">
					Ajouter la première dépense
				</a>
			{% endif %}
		</div>
	{% else %}
		<div class="overflow-x-auto rounded-xl border border-gray-100 shadow-xs bg-white">
			<table class="table w-full text-left border-collapse mb-0">
				<thead>
					<tr class="bg-gray-50/75 border-b border-gray-100">
						<th class="p-4 text-xs font-semibold text-gray-500 uppercase">Date</th>
						<th class="p-4 text-xs font-semibold text-gray-500 uppercase">Description</th>
						<th class="p-4 text-xs font-semibold text-gray-500 uppercase text-right">Montant</th>
						{% if not this.projectLocked %}
							<th class="p-4 text-xs font-semibold text-gray-500 uppercase text-center w-24">Actions</th>
						{% endif %}
					</tr>
				</thead>
				<tbody class="divide-y divide-gray-100">
					{% for expense in project.expenses %}
						<tr class="transition-colors hover:bg-gray-50/40">
							<td class="p-4 whitespace-nowrap text-xs text-gray-500">
								{{ expense.createdAt|date('d/m/Y H:i') }}
							</td>
							<td class="p-4 font-medium text-brand-dark text-sm">
								{{ expense.description }}
							</td>
							<td class="p-4 text-right font-extrabold text-brand-dark text-sm whitespace-nowrap">
								{{ expense.amount|number_format(2, ',', ' ') }}
								€
							</td>
							{% if not this.projectLocked %}
								<td class="p-4 text-center">
									<button type="button" data-action="live#action" data-live-action-param="removeExpense" data-live-expenseid-param="{{ expense.id }}" data-confirm="Êtes-vous sûr de vouloir supprimer cette dépense ?" class="text-danger hover:underline font-semibold text-xs cursor-pointer bg-transparent border-0 p-0">
										Supprimer
									</button>
								</td>
							{% endif %}
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>
	{% endif %}
</div>
