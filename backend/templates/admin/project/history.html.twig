{# templates/dashboard/project/history.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Historique du projet -
	{{ project.title }}
{% endblock %}

{% block body %}
	<div
		class="container mx-auto px-4 py-8 space-y-8">

		{# =========================================================================
		       1. EN-TÊTE DE NAVIGATION & RETOUR
		       ========================================================================= #}
		<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-gray-100 pb-6">
			<div>
				<h1 class="text-3xl font-extrabold text-brand-dark tracking-tight mb-1">
					Historique de
					{{ project.title }}
				</h1>
				<p class="text-sm text-gray-500">Journal d'audit complet des actions réalisées.</p>
			</div>
			{# Redirection vers la fiche projet principale (ajustez le nom de la route si nécessaire) #}
			<a href="{{ path('admin_project_read', {'id': project.id}) }}" class="btn-secondary text-sm inline-flex items-center gap-2">
				<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
				Retour au projet
			</a>
		</div>

		{# =========================================================================
		       2. BLOC STATISTIQUES (KPIs par type d'actions)
		       ========================================================================= #}
		{% if histories|length > 0 %}
			<div class="soft-card p-6 bg-white border border-gray-100 shadow-2xs">
				<h2 class="text-xs font-bold text-brand-dark uppercase tracking-wider mb-4">Statistiques d'Activité</h2>

				<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
					{% for action, count in actionCounts %}
						<div class="bg-gray-50/50 dark:bg-gray-800/40 border border-gray-100/50 p-4 rounded-xl text-center hover:border-gray-200 hover:shadow-2xs transition-all">
							<div class="text-2xl font-extrabold text-brand-dark">{{ count }}</div>
							<div class="text-[10px] font-bold text-gray-500 uppercase tracking-wide mt-1 leading-tight">
								{{ action|replace({
                                'created': 'Créations',
                                'updated': 'Mises à jour',
                                'status_changed': 'Statuts',
                                'expense_added': 'Dépenses +',
                                'expense_removed': 'Dépenses -',
                                'collaborator_added': 'Membres +',
                                'collaborator_removed': 'Membres -',
                                'client_assigned': 'Client',
                                'media_removed': 'Médias -',
                                'project_deleted': 'Suppression'
                            }) }}
							</div>
						</div>
					{% endfor %}
				</div>
			</div>
		{% endif %}

		{# =========================================================================
		       3. TIMELINE DES ACTIONS (Journal chronologique)
		       ========================================================================= #}
		<div class="soft-card p-6 bg-white border border-gray-100 shadow-2xs space-y-4">
			<h2 class="text-xs font-bold text-brand-dark uppercase tracking-wider mb-0">Timeline des actions</h2>

			{% if histories|length > 0 %}
				<div class="space-y-4 pt-2">
					{% for history in histories %}
						<div
							class="flex items-start gap-4 p-4 bg-white dark:bg-gray-900 border border-gray-100/80 rounded-xl shadow-3xs border-l-4 {{ history.getActionBadgeClass() }} hover:shadow-2xs hover:border-gray-200 transition-all duration-200">

							{# Badge Icone #}
							<div class="text-2xl shrink-0 p-1.5 bg-gray-50 dark:bg-gray-800 rounded-lg" aria-hidden="true">
								{{ history.getActionIcon() }}
							</div>

							{# Corps de l'information #}
							<div class="flex-1 min-w-0">
								<div class="flex flex-wrap justify-between items-start gap-2">
									<div>
										<p class="text-sm font-semibold text-brand-dark mb-0">
											<strong class="text-brand-dark font-bold">{{ history.user.fullName ?? history.user.email }}</strong>
											a
											<span class="text-brand-primary font-bold">{{ history.getActionLabel() }}</span>
										</p>

										{# Détails additionnels optionnels stylisés #}
										{% if history.details %}
											<p class="text-xs text-gray-500 mt-2 leading-relaxed bg-gray-50/75 dark:bg-gray-800/40 p-2.5 rounded-lg border border-gray-100/50">
												{{ history.details }}
											</p>
										{% endif %}
									</div>

									{# Horodatage #}
									<span class="text-[10px] text-gray-400 font-mono bg-gray-100/70 dark:bg-gray-800 px-2 py-0.5 rounded border border-gray-100">
										{{ history.createdAt|date('d/m/Y H:i') }}
									</span>
								</div>
							</div>

						</div>
					{% endfor %}
				</div>
			{% else %}
				<div class="text-center py-12 border-2 border-dashed border-gray-150 rounded-xl">
					<span class="text-3xl block mb-2" role="img" aria-label="Boîte vide">⏳</span>
					<p class="text-gray-400 font-medium mb-0">Aucune action enregistrée pour ce projet.</p>
				</div>
			{% endif %}
		</div>
	</div>
{% endblock %}
