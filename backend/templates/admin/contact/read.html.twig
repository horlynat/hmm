{# templates/admin/contact/read.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Message :
	{{ message.subject }}
{% endblock %}

{% block body %}
	<main class="container mx-auto px-4 py-8">

		<div class="mb-6">
			<a href="{{ path('admin_contact_index') }}" class="btn btn-secondary gap-2 px-3 py-2 text-sm w-fit">
				<span class="material-icons text-base">arrow_back</span>
				<span>Retour à la liste des messages</span>
			</a>
		</div>

		<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">

			<!-- 📖 CONTENU (70%) -->
			<div class="lg:col-span-2 card space-y-6">
				<div>
					<span class="badge {{ message.status.getBadgeClass() }}">{{ message.status.getLabel() }}</span>
					<h1 class="text-3xl font-heading font-bold tracking-tight mt-3 text-brand-dark">
						{{ message.subject }}
					</h1>
					<p class="text-sm opacity-60 mt-1">De {{ message.name }} ({{ message.email }}) — {{ message.createdAt ? message.createdAt|date('d/m/Y H:i') : '—' }}</p>
				</div>

				<div class="leading-relaxed text-base space-y-4 whitespace-pre-line border-t border-gray-100 pt-6 text-brand-dark/80">
					{{ message.message }}
				</div>
			</div>

			<!-- ⚙️ INFOS LATÉRALES (30%) -->
			<div class="space-y-6">
				<div class="card space-y-4">
					<h3 class="text-xs font-bold uppercase tracking-wider opacity-40 border-b border-gray-100 pb-2">
						Fiche Technique
					</h3>

					<div class="space-y-3 text-sm">
						<div class="flex justify-between items-center">
							<span class="opacity-60">Nom :</span>
							<span class="font-bold text-brand-dark">{{ message.name }}</span>
						</div>
						<div class="flex justify-between items-center">
							<span class="opacity-60">Email :</span>
							<span class="font-bold text-brand-dark">{{ message.email }}</span>
						</div>
					</div>

					<div class="pt-4 border-t border-gray-100 flex flex-col gap-3">
						{% if message.status.value != 'archive' %}
							<form method="post" action="{{ path('admin_contact_archive', {'id': message.id}) }}" class="w-full">
								<input type="hidden" name="_token" value="{{ csrf_token('archive_' ~ message.id) }}">
								<button type="submit" class="btn btn-secondary w-full text-sm gap-2">
									<span class="material-icons text-sm">archive</span>
									<span>Archiver</span>
								</button>
							</form>
						{% endif %}
						<div class="w-full [&>div]:w-full [&>div>form]:w-full text-center">
							{% include 'admin/contact/_delete_form.html.twig' with {'message': message} %}
						</div>
					</div>
				</div>
			</div>

		</div>
	</main>
{% endblock %}
