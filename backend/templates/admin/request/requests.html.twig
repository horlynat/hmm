{# templates/admin/request/requests.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Demandes de devis
{% endblock %}

{% block body %}
	<main class="container mx-auto px-4 py-8">

		<!-- 📑 EN-TÊTE -->
		<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
			<div>
				<h1 class="text-3xl font-heading font-bold flex items-center gap-2 text-brand-dark">
					<span class="material-icons text-brand-primary">request_quote</span>
					<span>Demandes de devis</span>
				</h1>
				<p class="text-sm opacity-60 mt-1">Gérez les demandes de devis, support et partenariats reçues des clients.</p>
			</div>
		</div>

		<!-- 🔎 FILTRES -->
		<form method="get" class="soft-card mb-6 flex flex-col sm:flex-row gap-3 sm:items-end p-4">
			<div class="flex-1">
				<label class="text-xs font-bold uppercase opacity-60">Recherche</label>
				<input type="text" name="search" value="{{ filters.search }}" placeholder="Nom, email, message..." class="input w-full mt-1">
			</div>
			<div>
				<label class="text-xs font-bold uppercase opacity-60">Statut</label>
				<select name="status" class="input mt-1">
					<option value="">Tous</option>
					<option value="pending" {% if filters.status == 'pending' %}selected{% endif %}>En attente</option>
					<option value="accepted" {% if filters.status == 'accepted' %}selected{% endif %}>Acceptées</option>
					<option value="rejected" {% if filters.status == 'rejected' %}selected{% endif %}>Refusées</option>
				</select>
			</div>
			<button type="submit" class="btn btn-primary">Filtrer</button>
		</form>

		<!-- 📊 TABLEAU -->
		<div class="soft-card">
			<table class="table">
				<thead>
					<tr>
						<th class="w-24">Id</th>
						<th>Statut</th>
						<th>Demandeur</th>
						<th>Téléphone</th>
						<th class="w-24 text-right">Actions</th>
					</tr>
				</thead>
				<tbody>
					{% for quoteRequest in requests %}
						<tr>
							<td class="font-mono text-xs opacity-50">{{ quoteRequest.id }}</td>
							<td>
								{% if quoteRequest.status is null %}
									<span class="badge bg-yellow-500 text-black">En attente</span>
								{% elseif quoteRequest.status %}
									<span class="badge bg-green-500 text-white">Acceptée</span>
								{% else %}
									<span class="badge bg-red-500 text-white">Refusée</span>
								{% endif %}
							</td>
							<td>
								<div>{{ quoteRequest.name }}</div>
								<div class="text-xs opacity-60">{{ quoteRequest.email }}</div>
							</td>
							<td class="text-sm opacity-70">{{ quoteRequest.phone }}</td>
							<td>
								<div class="flex items-center justify-end gap-2">
									<a href="{{ path('admin_request_read', {'id': quoteRequest.id}) }}" class="p-2 hover:bg-brand-light rounded-sm transition-colors text-brand-dark" title="Voir">
										<span class="material-icons text-lg block">visibility</span>
									</a>
									{% include 'admin/request/_delete_form.html.twig' with {'quoteRequest': quoteRequest} %}
								</div>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="5" class="text-center py-12 opacity-40">
								<span class="material-icons text-4xl block mb-2">inbox</span>
								Aucune demande pour le moment.
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>
	</main>
{% endblock %}
