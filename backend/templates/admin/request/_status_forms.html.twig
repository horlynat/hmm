{# templates/admin/request/_status_forms.html.twig #}
<div class="flex flex-col gap-3">
	{% if quoteRequest.status is not same as(true) %}
		<form method="post" action="{{ path('admin_request_accept', {'id': quoteRequest.id}) }}" class="w-full">
			<input type="hidden" name="_token" value="{{ csrf_token('request_status_' ~ quoteRequest.id) }}">
			<button type="submit" class="btn w-full text-sm gap-2 bg-green-500 text-white border-0">
				<span class="material-icons text-sm">check_circle</span>
				<span>Accepter</span>
			</button>
		</form>
	{% endif %}

	{% if quoteRequest.status is not same as(false) %}
		<form method="post" action="{{ path('admin_request_reject', {'id': quoteRequest.id}) }}" class="w-full">
			<input type="hidden" name="_token" value="{{ csrf_token('request_status_' ~ quoteRequest.id) }}">
			<button type="submit" class="btn w-full text-sm gap-2 bg-danger text-white border-0">
				<span class="material-icons text-sm">cancel</span>
				<span>Refuser</span>
			</button>
		</form>
	{% endif %}

	{% if quoteRequest.status is not null %}
		<form method="post" action="{{ path('admin_request_reset', {'id': quoteRequest.id}) }}" class="w-full">
			<input type="hidden" name="_token" value="{{ csrf_token('request_status_' ~ quoteRequest.id) }}">
			<button type="submit" class="btn btn-secondary w-full text-sm gap-2">
				<span class="material-icons text-sm">restart_alt</span>
				<span>Réinitialiser (en attente)</span>
			</button>
		</form>
	{% endif %}
</div>
