{# templates/admin/skill/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Gestion des compétences
{% endblock %}

{% block body %}
	<main class="container mx-auto px-4 py-8">

		<!-- 📑 EN-TÊTE -->
		<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
			<div>
				<h1 class="text-3xl font-heading font-bold flex items-center gap-2 text-brand-dark">
					<span class="material-icons text-brand-primary">psychology</span>
					<span>Gestion des compétences</span>
				</h1>
				<p class="text-sm opacity-60 mt-1">Gérez votre expertise et vos acquis techniques.</p>
			</div>
			<a href="{{ path('admin_skill_create') }}" class="btn btn-primary gap-2">
				<span class="material-icons text-sm">add_circle</span>
				<span>Ajouter une compétence</span>
			</a>
		</div>

		<!-- 📊 TABLEAU -->
		<div class="soft-card">
			<table class="table">
				<thead>
					<tr>
						<th class="w-16">Id</th>
						<th>Nom</th>
						<th>Niveau</th>
						<th class="w-40 text-right">Actions</th>
					</tr>
				</thead>
				<tbody>
					{% for skill in skills %}
						<tr>
							<td class="font-mono text-xs opacity-50">{{ skill.id }}</td>
							<td class="font-bold text-brand-dark">{{ skill.name }}</td>
							<td>
								<span class="badge bg-brand-light text-brand-primary">{{ skill.level }}</span>
							</td>
							<td>
								<div class="flex items-center justify-end gap-2">
									<a href="{{ path('admin_skill_read', {'id': skill.id}) }}" class="p-2 hover:bg-brand-light rounded-sm transition-colors text-brand-dark" title="Voir">
										<span class="material-icons text-lg block">visibility</span>
									</a>
									<a href="{{ path('admin_skill_update', {'id': skill.id}) }}" class="p-2 hover:bg-warning/20 rounded-sm transition-colors text-warning" title="Modifier">
										<span class="material-icons text-lg block">edit</span>
									</a>
									{{ include('admin/skill/_delete_form.html.twig', {'skill': skill}) }}
								</div>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="4" class="text-center py-12 opacity-40">
								<span class="material-icons text-4xl block mb-2">psychology</span>
								<span>Aucune compétence trouvée.</span>
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>
	</main>
{% endblock %}
