{# templates/admin/tag/_delete_form.html.twig #}
<div
	class="inline-block">

	<!-- 🗑️ BOUTON DÉCLENCHEUR -->
	<button type="button" onclick="document.getElementById('delete-modal-{{ tag.id }}').showModal()" class="p-2 hover:bg-danger/10 text-danger rounded-sm transition-colors flex items-center justify-center cursor-pointer" title="Supprimer le tag">
		<span class="material-icons text-lg block">delete_forever</span>
	</button>

	<!-- 🖼️ MODAL NATIF (DIALOG) -->
	<dialog id="delete-modal-{{ tag.id }}" class="card p-6 max-w-md w-full bg-bg-card backdrop:bg-brand-dark/40 backdrop:backdrop-blur-sm shadow-2xl border-0">

		<div
			class="text-center">
			<!-- Icône d'avertissement -->
			<div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-danger/10 text-danger mb-4">
				<span class="material-icons text-2xl">warning</span>
			</div>

			<!-- Message de confirmation -->
			<h3 class="text-lg font-heading font-bold text-brand-dark">Supprimer ce tag ?</h3>
			<p class="text-sm opacity-80 mt-2 px-2">
				Êtes-vous sûr de vouloir supprimer le tag
				<span class="font-bold text-brand-dark">"{{ tag.name }}"</span>
				? Cette action est irréversible et le dissociera de vos différents contenus actifs.
			</p>

			<!-- Actions du Modal -->
			<div
				class="mt-6 flex flex-col sm:flex-row-reverse gap-3">
				<!-- Formulaire Réel de Soumission -->
				<form method="post" action="{{ path('admin_tag_delete', {'id': tag.id}) }}" class="w-full sm:w-auto flex-1">
					<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tag.id) }}">
					<button type="submit" onclick="this.disabled=true; this.form.submit();" class="btn bg-danger text-white w-full gap-2 px-4 py-2 border-0">
						Confirmer
					</button>
				</form>

				<!-- Bouton Annuler -->
				<button type="button" onclick="document.getElementById('delete-modal-{{ tag.id }}').close()" class="btn btn-secondary w-full sm:w-auto flex-1 px-4 py-2">
					Annuler
				</button>
			</div>
		</div>

	</dialog>
</div>
