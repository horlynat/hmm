{# templates/admin/tag/read.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Détails :
	{{ tag.name }}
{% endblock %}

{% block body %}
	<main class="container mx-auto px-4 py-8">

		<div class="mb-6">
			<a href="{{ path('admin_tag_index') }}" class="btn btn-secondary gap-2 px-3 py-2 text-sm w-fit">
				<span class="material-icons text-base">arrow_back</span>
				<span>Retour à la liste des tags</span>
			</a>
		</div>

		<div
			class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">

			<!-- 📖 CONTENU (70%) -->
			<div class="lg:col-span-2 card space-y-6">
				<div>
					<span class="badge bg-brand-light text-brand-primary">
						ID : #{{ tag.id }}
					</span>
					<h1 class="text-3xl font-heading font-bold tracking-tight mt-3 text-brand-dark">
						{{ tag.name }}
					</h1>
				</div>

				<div class="leading-relaxed text-base space-y-4 whitespace-pre-line border-t border-gray-100 pt-6 text-brand-dark/80">
					<p>
						Cette étiquette est associée à vos articles ou projets afin de structurer et d'organiser vos publications pour les visiteurs du site.
					</p>
				</div>
			</div>

			<!-- ⚙️ INFOS LATÉRALES (30%) -->
			<div class="space-y-6">
				<div class="card space-y-4">
					<h3 class="text-xs font-bold uppercase tracking-wider opacity-40 border-b border-gray-100 pb-2">
						Fiche Technique
					</h3>

					<div class="space-y-3 text-sm">
						<div class="flex justify-between items-center">
							<span class="opacity-60">Nom :</span>
							<span class="font-bold text-brand-dark">{{ tag.name }}</span>
						</div>
					</div>

					<div class="pt-4 border-t border-gray-100 flex flex-col gap-3">
						<a href="{{ path('admin_tag_update', {'id': tag.id}) }}" class="btn btn-primary w-full text-sm gap-2">
							<span class="material-icons text-sm">edit</span>
							<span>Modifier le tag</span>
						</a>
						<div class="w-full [&>form]:w-full text-center">
							{% include 'admin/tag/_delete_form.html.twig' with {'tag': tag} %}
						</div>
					</div>
				</div>
			</div>

		</div>
	</main>
{% endblock %}
