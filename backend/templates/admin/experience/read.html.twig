{# templates/admin/experience/read.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Détails :
	{{ experience.role }}
{% endblock %}

{% block body %}
	<main class="container mx-auto px-4 py-8">

		<div class="mb-6">
			<a href="{{ path('admin_experience_index') }}" class="btn btn-secondary gap-2 px-3 py-2 text-sm w-fit">
				<span class="material-icons text-base">arrow_back</span>
				<span>Retour à la liste</span>
			</a>
		</div>

		<div
			class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">

			<!-- 📖 CONTENU (70%) -->
			<div class="lg:col-span-2 card space-y-6">
				<div>
					<span class="badge bg-brand-light text-brand-primary">ID : #{{ experience.id }}</span>
					<h1 class="text-3xl font-heading font-bold tracking-tight mt-3 text-brand-dark">
						{{ experience.role }}
					</h1>
					<p class="text-lg opacity-80 mt-1 flex items-center gap-1.5 font-bold text-brand-primary">
						<span class="material-icons text-base">business</span>
						{{ experience.company }}
					</p>
				</div>

				<div class="leading-relaxed text-base space-y-4 whitespace-pre-line border-t border-gray-100 pt-6">
					{{ experience.description ?: '<em class="opacity-40">Aucune description renseignée pour cette mission.</em>'|raw }}
				</div>
			</div>

			<!-- ⚙️ INFOS LATÉRALES (30%) -->
			<div class="space-y-6">
				<div class="card space-y-4">
					<h3 class="text-xs font-bold uppercase tracking-wider opacity-40 border-b border-gray-100 pb-2">
						Période & Détails
					</h3>

					<div class="space-y-3 text-sm">
						<div class="flex justify-between items-center">
							<span class="opacity-60">Début :</span>
							<span class="font-bold">{{ experience.startDate ? experience.startDate|date('d/m/Y') : '—' }}</span>
						</div>
						<div class="flex justify-between items-center">
							<span class="opacity-60">Fin :</span>
							<span class="font-bold">{{ experience.endDate ? experience.endDate|date('d/m/Y') : 'En poste' }}</span>
						</div>
					</div>

					<div class="pt-4 border-t border-gray-100 flex flex-col gap-3">
						<a href="{{ path('admin_experience_update', {'id': experience.id}) }}" class="btn btn-primary w-full text-sm gap-2">
							<span class="material-icons text-sm">edit</span>
							<span>Modifier l'expérience</span>
						</a>
						<div class="w-full [&>form]:w-full text-center">
							{{ include('admin/experience/_delete_form.html.twig', {'experience': experience}) }}
						</div>
					</div>
				</div>
			</div>

		</div>
	</main>
{% endblock %}
