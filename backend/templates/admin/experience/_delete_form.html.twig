{# templates/admin/experience/_delete_form.html.twig #}
<div
	class="inline-block">

	<!-- 🗑️ BOUTON DÉCLENCHEUR -->
	<button type="button" onclick="document.getElementById('delete-modal-{{ experience.id }}').showModal()" class="p-2 hover:bg-danger/10 text-danger rounded-sm transition-colors flex items-center justify-center cursor-pointer" title="Supprimer l'expérience">
		<span class="material-icons text-lg block">delete_forever</span>
	</button>

	<!-- 🖼️ MODAL NATIF (DIALOG) -->
	<dialog id="delete-modal-{{ experience.id }}" class="card p-6 max-w-md w-full bg-bg-card backdrop:bg-brand-dark/40 backdrop:backdrop-blur-sm shadow-2xl border-0">

		<div
			class="text-center">
			<!-- Icône d'avertissement -->
			<div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-danger/10 text-danger mb-4">
				<span class="material-icons text-2xl">warning</span>
			</div>

			<!-- Message de confirmation -->
			<h3 class="text-lg font-heading font-bold text-brand-dark">Supprimer cette expérience ?</h3>
			<p class="text-sm opacity-80 mt-2 px-2">
				Êtes-vous sûr de vouloir supprimer l'expérience de
				<span class="font-bold text-brand-dark">"{{ experience.role }}"</span>
				chez
				<span class="font-bold">{{ experience.company }}</span>
				? Cette action est irréversible.
			</p>

			<!-- Actions du Modal -->
			<div
				class="mt-6 flex flex-col sm:flex-row-reverse gap-3">
				<!-- Formulaire Réel -->
				<form method="post" action="{{ path('admin_experience_delete', {'id': experience.id}) }}" class="w-full sm:w-auto flex-1">
					<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ experience.id) }}">
					<button type="submit" onclick="this.disabled=true; this.form.submit();" class="btn bg-danger text-white w-full gap-2 px-4 py-2 border-0">
						Confirmer
					</button>
				</form>

				<!-- Bouton Annuler -->
				<button type="button" onclick="document.getElementById('delete-modal-{{ experience.id }}').close()" class="btn btn-secondary w-full sm:w-auto flex-1 px-4 py-2">
					Annuler
				</button>
			</div>
		</div>

	</dialog>
</div>
