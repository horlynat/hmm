{# templates/admin/experience/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Gestion des expériences
{% endblock %}

{% block body %}
	<main
		class="container mx-auto px-4 py-8">

		<!-- 📑 EN-TÊTE -->
		<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
			<div>
				<h1 class="text-3xl font-heading font-bold flex items-center gap-2 text-brand-dark">
					<span class="material-icons text-brand-primary">work</span>
					<span>Gestion des expériences</span>
				</h1>
				<p class="text-sm opacity-60 mt-1">Gérez votre parcours professionnel et vos postes occupés.</p>
			</div>
			<a href="{{ path('admin_experience_create') }}" class="btn btn-primary gap-2">
				<span class="material-icons text-sm">add_circle</span>
				<span>Ajouter une expérience</span>
			</a>
		</div>

		<!-- 📊 TABLEAU -->
		<div class="soft-card">
			<table class="table">
				<thead>
					<tr>
						<th class="w-16">Id</th>
						<th>Poste & Entreprise</th>
						<th class="w-48">Période</th>
						<th class="w-40 text-right">Actions</th>
					</tr>
				</thead>
				<tbody class="divide-y divide-gray-200">
					{% for experience in experiences %}
						<tr>
							<td class="font-mono text-xs opacity-50">{{ experience.id }}</td>
							<td>
								<div class="font-bold text-base truncate text-brand-dark">{{ experience.role }}</div>
								<div class="text-xs opacity-70 flex items-center gap-1 mt-0.5">
									<span class="material-icons text-[14px]">business</span>
									{{ experience.company }}
								</div>
							</td>
							<td class="text-xs opacity-80">
								<div class="flex flex-col gap-0.5">
									<span>Du :
										{{ experience.startDate ? experience.startDate|date('d/m/Y') : '—' }}</span>
									<span>Au :
										{{ experience.endDate ? experience.endDate|date('d/m/Y') : '—' }}</span>
								</div>
							</td>
							<td>
								<div class="flex items-center justify-end gap-2">
									<a href="{{ path('admin_experience_read', {'id': experience.id}) }}" class="p-2 hover:bg-brand-light rounded-sm transition-colors text-brand-dark" title="Voir">
										<span class="material-icons text-lg block">visibility</span>
									</a>
									<a href="{{ path('admin_experience_update', {'id': experience.id}) }}" class="p-2 hover:bg-warning/20 rounded-sm transition-colors text-warning" title="Modifier">
										<span class="material-icons text-lg block">edit</span>
									</a>
									{{ include('admin/experience/_delete_form.html.twig', {'experience': experience}) }}
								</div>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="4" class="text-center py-12 opacity-40">
								<span class="material-icons text-4xl block mb-2">work_off</span>
								<span>Aucune expérience trouvée pour le moment.</span>
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>
	</main>
{% endblock %}
