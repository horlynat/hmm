{% extends 'base.html.twig' %}

{% block title %}Gestion des projets
{% endblock %}

{% block body %}
	<main
		class="p-8 bg-gray-50 min-h-screen">

		<!-- Header -->
		<div class="flex justify-between items-center mb-8">
			<h1 class="text-2xl font-bold text-gray-800 flex items-center space-x-2">
				<span class="material-icons text-indigo-600">folder</span>
				<span>Gestion des projets</span>
			</h1>
			<a href="{{ path('project_create') }}" class="px-5 py-2 bg-linear-to-r from-indigo-600 to-blue-600 text-white rounded-lg shadow hover:scale-105 transform transition flex items-center space-x-2">
				<span class="material-icons">add_circle</span>
				<span>Créer un nouveau projet</span>
			</a>
		</div>

		<!-- Flash Messages -->
		{% for message in app.flashes('success') %}
			<div class="mb-4 p-4 bg-green-100 border border-green-400 text-green-700 rounded-lg">
				{{ message }}
			</div>
		{% endfor %}
		{% for message in app.flashes('error') %}
			<div class="mb-4 p-4 bg-red-100 border border-red-400 text-red-700 rounded-lg">
				{{ message }}
			</div>
		{% endfor %}

		<!-- Table -->
		<div class="bg-white rounded-xl shadow overflow-hidden">
			<table class="min-w-full text-left">
				<thead class="bg-gray-100 text-gray-600 uppercase text-sm sticky top-0">
					<tr>
						<th class="px-6 py-3">Id</th>
						<th class="px-6 py-3">Titre</th>
						<th class="px-6 py-3">Slug</th>
						<th class="px-6 py-3">Description</th>
						<th class="px-6 py-3">Lien</th>
						<th class="px-6 py-3">Actions</th>
					</tr>
				</thead>
				<tbody class="divide-y divide-gray-200">
					{% for project in projects %}
						<tr class="hover:bg-gray-50 transition">
							<td class="px-6 py-4 text-gray-700">{{ project.id }}</td>
							<td class="px-6 py-4 font-semibold text-gray-800">{{ project.title }}</td>
							<td class="px-6 py-4 text-gray-600">{{ project.slug }}</td>
							<td class="px-6 py-4 text-gray-600 truncate max-w-xs">{{ project.description }}</td>
							<td class="px-6 py-4 text-blue-600 underline">
								<a href="{{ project.link }}" target="_blank">{{ project.link }}</a>
							</td>
							<td class="px-6 py-4 flex space-x-3">
								<a href="{{ path('project_read', {'id': project.id}) }}" class="px-3 py-1 bg-blue-100 text-blue-700 rounded-lg hover:bg-blue-200 transition flex items-center space-x-1 text-sm">
									<span class="material-icons text-sm">visibility</span>
									<span>Détails</span>
								</a>
								<a href="{{ path('project_update', {'id': project.id}) }}" class="px-3 py-1 bg-yellow-100 text-yellow-700 rounded-lg hover:bg-yellow-200 transition flex items-center space-x-1 text-sm">
									<span class="material-icons text-sm">edit</span>
									<span>Modifier</span>
								</a>
								{% include 'project/_delete_form.html.twig' with { project: project } %}
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="6" class="px-6 py-12 text-center">
								<div class="flex flex-col items-center space-y-3">
									<span class="material-icons text-gray-400 text-5xl">inbox</span>
									<p class="text-gray-500">Aucun projet trouvé</p>
									<a href="{{ path('project_create') }}" class="px-4 py-2 bg-indigo-600 text-white rounded-lg shadow hover:bg-indigo-700 transition">
										Créer un projet
									</a>
								</div>
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>

		<!-- Pagination -->
		<div class="flex justify-center items-center mt-6 space-x-2">
			<a href="#" class="px-3 py-1 rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition">&laquo;</a>
			<a href="#" class="px-3 py-1 rounded-lg bg-indigo-600 text-white shadow">1</a>
			<a href="#" class="px-3 py-1 rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition">2</a>
			<a href="#" class="px-3 py-1 rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition">3</a>
			<a href="#" class="px-3 py-1 rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition">&raquo;</a>
		</div>
	</main>
{% endblock %}

