{% extends 'base.html.twig' %}

{% block title %}Détails du projet
{% endblock %}

{% block body %}
	<main
		class="p-8 bg-gray-50 min-h-screen">

		<!-- Header -->
		<div class="flex justify-between items-center mb-8">
			<h1 class="text-2xl font-bold text-gray-800 flex items-center space-x-2">
				<span class="material-icons text-indigo-600">folder</span>
				<span>Détails du projet</span>
			</h1>
			<a href="{{ path('admin_project_index') }}" class="px-5 py-2 bg-gray-200 text-gray-700 rounded-lg shadow hover:bg-gray-300 transition flex items-center space-x-2">
				<span class="material-icons">arrow_back</span>
				<span>Retour à la liste</span>
			</a>
		</div>

		<!-- Card détails -->
		<div class="bg-white p-8 rounded-xl shadow-lg border border-gray-100 space-y-6">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				<div>
					<p class="text-sm text-gray-500">ID</p>
					<p class="text-lg font-semibold text-gray-800">{{ project.id }}</p>
				</div>
				<div>
					<p class="text-sm text-gray-500">Titre</p>
					<p class="text-lg font-semibold text-gray-800">{{ project.title }}</p>
				</div>
				<div>
					<p class="text-sm text-gray-500">Slug</p>
					<p class="text-lg font-semibold text-gray-800">{{ project.slug }}</p>
				</div>
				<div class="md:col-span-2">
					<p class="text-sm text-gray-500">Description</p>
					<p class="text-gray-700 mt-2">{{ project.description }}</p>
				</div>
				<div class="md:col-span-2">
					<p class="text-sm text-gray-500">Lien</p>
					{% if project.link %}
						<a href="{{ project.link }}" target="_blank" class="text-indigo-600 underline hover:text-indigo-800 transition">
							{{ project.link }}
						</a>
					{% else %}
						<span class="text-gray-400">Aucun lien disponible</span>
					{% endif %}
				</div>
			</div>
		</div>

		<!-- Actions -->
		<div class="flex space-x-4 mt-6">
			<a href="{{ path('admin_project_update', {'id': project.id}) }}" class="px-5 py-2 bg-yellow-100 text-yellow-700 rounded-lg shadow hover:bg-yellow-200 transition flex items-center space-x-2">
				<span class="material-icons">edit</span>
				<span>Modifier</span>
			</a>
			{{ include('admin/project/_delete_form.html.twig') }}
		</div>
	</main>
{% endblock %}

