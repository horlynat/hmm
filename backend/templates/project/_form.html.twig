<!-- Formulaire premium compact -->
<div class="bg-white p-6 rounded-lg shadow-md border border-gray-100">
	{{ form_start(form, {'attr': {'class': 'space-y-4'}}) }}

	<!-- Champ Titre du projet -->
	<div>
		<label class="block text-sm font-medium text-gray-700 mb-1">Titre du projet</label>
		{{ form_widget(form.title, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-indigo-600 focus:outline-none'}}) }}
		{% if form_errors(form.title) %}
			<p class="text-red-600 text-xs mt-1">{{ form_errors(form.title) }}</p>
		{% endif %}
	</div>

	<!-- Champ Description -->
	<div>
		<label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
		{{ form_widget(form.description, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-indigo-600 focus:outline-none h-24'}}) }}
		{% if form_errors(form.description) %}
			<p class="text-red-600 text-xs mt-1">{{ form_errors(form.description) }}</p>
		{% endif %}
	</div>

	<!-- Champ Technologies -->
	<div>
		<label class="block text-sm font-medium text-gray-700 mb-1">Technologies utilisées</label>
		{{ form_widget(form.skill, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-indigo-600 focus:outline-none'}}) }}
		<p class="text-xs text-gray-500 mt-1">Sélectionne une ou plusieurs technologies liées au projet.</p>
		{% if form_errors(form.skill) %}
			<p class="text-red-600 text-xs mt-1">{{ form_errors(form.skill) }}</p>
		{% endif %}
	</div>

	<!-- Champ Lien -->
	<div>
		<label class="block text-sm font-medium text-gray-700 mb-1">Lien du projet</label>
		{{ form_widget(form.link, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-indigo-600 focus:outline-none'}}) }}
		{% if form_errors(form.link) %}
			<p class="text-red-600 text-xs mt-1">{{ form_errors(form.link) }}</p>
		{% endif %}
	</div>

	<!-- Bouton CTA -->
	<div class="flex justify-end">
		<button class="px-5 py-2 bg-gradient-to-r from-indigo-600 to-blue-600 text-white rounded-md shadow hover:scale-105 transform transition flex items-center space-x-2">
			<span class="material-icons text-sm">save</span>
			<span>{{ button_label|default('Enregistrer') }}</span>
		</button>
	</div>

	{{ form_end(form) }}
</div>