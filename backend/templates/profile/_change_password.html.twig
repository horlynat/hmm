{# templates/profile/_change_password.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Changer le mot de passe
{% endblock %}

{% block profile_content %}

	<div class="max-w-md mx-auto py-8 px-4">
		<h1 class="text-2xl font-bold mb-6 text-gray-800 dark:text-gray-200">Changer le mot de passe</h1>

		{{ form_start(form, {'attr': {'class': 'bg-white dark:bg-gray-800 shadow-md rounded-lg p-6 border border-gray-200 dark:border-gray-700'}}) }}

		{# Erreurs globales du formulaire #}
		{{ form_errors(form, {'attr': {'class': 'mb-4 p-4 bg-red-100 dark:bg-red-900 text-red-700 dark:text-red-300 rounded'}}) }}

		<div class="space-y-4">
			<div>
				{{ form_label(form.plainPassword, 'Nouveau mot de passe', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-gray-300'}}) }}
				{{ form_widget(form.plainPassword, {'attr': {'class': 'mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-gray-800 dark:text-gray-200'}}) }}
				{{ form_errors(form.plainPassword, {'attr': {'class': 'text-red-500 dark:text-red-400 text-xs mt-1'}}) }}
			</div>

			<div>
				{{ form_label(form.confirmPassword, 'Confirmer le mot de passe', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-gray-300'}}) }}
				{{ form_widget(form.confirmPassword, {'attr': {'class': 'mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-gray-800 dark:text-gray-200'}}) }}
				{{ form_errors(form.confirmPassword, {'attr': {'class': 'text-red-500 dark:text-red-400 text-xs mt-1'}}) }}
			</div>
		</div>

		<div class="mt-6 flex justify-end gap-4">
			<a href="{{ path('profile_read', {'id': user.id}) }}" class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:hover:bg-gray-600 transition">
				Annuler
			</a>
			<button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-md hover:bg-indigo-700 transition">
				Changer le mot de passe
			</button>
		</div>

		{{ form_end(form) }}
	</div>
{% endblock %}
