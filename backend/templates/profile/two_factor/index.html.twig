{# templates/profile/two_factor/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Double authentification{% endblock %}

{% block body %}
	<main class="container mx-auto px-4 py-8 max-w-2xl">

		<div class="mb-8">
			<h1 class="text-3xl font-heading font-bold flex items-center gap-2 text-brand-dark">
				<span class="material-icons text-brand-primary">shield_moon</span>
				<span>Double authentification (2FA)</span>
			</h1>
			<p class="text-sm opacity-60 mt-1">Sécurisez votre compte avec un code à usage unique généré par une application d'authentification (Google Authenticator, Authy, etc.).</p>
		</div>

		<div class="soft-card p-6">
			<div class="flex items-center justify-between">
				<div>
					<p class="text-sm opacity-60 mb-1">Statut</p>
					{% if user.isTotpAuthenticationEnabled %}
						<span class="badge bg-success/10 text-success">
							<span class="material-icons text-sm mr-1">check_circle</span>
							Activée
						</span>
					{% else %}
						<span class="badge bg-gray-200 text-gray-500">
							<span class="material-icons text-sm mr-1">cancel</span>
							Désactivée
						</span>
					{% endif %}
				</div>

				{% if user.isTotpAuthenticationEnabled %}
					<a href="{{ path('profile_two_factor_disable') }}" class="btn btn-secondary">
						<span class="material-icons text-base mr-1.5">lock_open</span>
						Désactiver
					</a>
				{% else %}
					<a href="{{ path('profile_two_factor_setup') }}" class="btn btn-primary">
						<span class="material-icons text-base mr-1.5">qr_code_2</span>
						Activer la 2FA
					</a>
				{% endif %}
			</div>

			{% if user.isTotpAuthenticationEnabled %}
				<p class="text-xs opacity-50 mt-4 pt-4 border-t border-gray-100">Un code sera demandé à chaque connexion, en plus de votre mot de passe.</p>
			{% endif %}
		</div>

		{% if user.isTotpAuthenticationEnabled %}
			{% set remaining = user.backupCodes|length %}
			<div class="soft-card p-6 mt-6">
				<div class="flex items-center justify-between mb-2">
					<h2 class="font-heading font-bold text-lg flex items-center gap-2 text-brand-dark">
						<span class="material-icons text-brand-primary">vpn_key</span>
						Codes de récupération
					</h2>
					<span class="badge {{ remaining > 2 ? 'bg-success/10 text-success' : 'bg-danger/10 text-danger' }}">
						{{ remaining }} restant{{ remaining > 1 ? 's' : '' }}
					</span>
				</div>
				<p class="text-sm opacity-60 mb-4">Ils vous permettent de vous connecter si vous perdez l'accès à votre application d'authentification. {% if remaining <= 2 %}<strong class="text-danger">Il vous en reste peu — pensez à en générer de nouveaux.</strong>{% endif %}</p>

				<form method="post" action="{{ path('profile_two_factor_recovery_codes_regenerate') }}" class="flex flex-wrap items-end gap-3">
					<input type="hidden" name="_token" value="{{ csrf_token('profile_two_factor_recovery_regenerate') }}">
					<div class="flex-1 min-w-[12rem]">
						<label for="regen_password" class="label block text-sm mb-1">Confirmez votre mot de passe</label>
						<input type="password" id="regen_password" name="password" required autocomplete="current-password" class="input input-primary w-full">
					</div>
					<button type="submit" class="btn btn-secondary">
						<span class="material-icons text-base mr-1.5">autorenew</span>
						Générer de nouveaux codes
					</button>
				</form>
				<p class="text-xs opacity-50 mt-3">Générer de nouveaux codes invalide immédiatement les anciens.</p>
			</div>
		{% endif %}
	</main>
{% endblock %}
