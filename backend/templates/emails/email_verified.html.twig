<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<title>Compte activé</title>
		<script src="https://cdn.tailwindcss.com"></script>
	</head>
	<body class="bg-gray-100 font-sans">

		<div
			class="max-w-xl mx-auto mt-10 bg-white shadow-xl rounded-lg overflow-hidden">
			<!-- Header -->
			<div class="bg-gradient-to-r from-green-600 to-emerald-600 p-6 text-center">
				<h1 class="text-3xl font-bold text-white">🎉 Votre compte est activé !</h1>
				<p class="text-green-100 mt-2">Bienvenue dans la communauté</p>
			</div>

			<!-- Body -->
			<div class="p-8">
				<p class="text-gray-700 mb-6">
					Bonjour
					<strong>{{ fullName }}</strong>,<br>
					Félicitations ! Votre compte a été activé avec succès.
				</p>

				<div class="text-center mb-8">
					<a href="{{ absolute_url(path('profile_read', {id: user.id})) }}" class="inline-block px-8 py-4 bg-green-600 text-white font-semibold rounded-lg shadow-lg hover:bg-green-700 transition transform hover:scale-105">
						👤 Accéder à mon profil
					</a>
				</div>

				<p class="text-sm text-gray-600">
					Vous pouvez désormais profiter pleinement de nos services.
				</p>
			</div>

			<!-- Footer -->
			<div class="bg-gray-50 p-6 text-center">
				<p class="text-gray-700 font-medium">Merci,<br>
					<span class="text-green-600">L’équipe Support Tech</span>
				</p>
			</div>
		</div>
	</body>
</html>

