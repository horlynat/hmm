{% extends 'emails/base_email.html.twig' %}

{% block body %}
	<div
		class="bg-white shadow-md rounded-lg p-6">
		<!-- En-tête -->
		<h1 class="text-2xl font-bold text-blue-900 mb-4">⚠️ Alerte de sécurité</h1>

		<!-- Message principal -->
		<p class="text-gray-700 mb-2">Bonjour
			<span class="font-semibold">{{ fullName }}</span>,</p>
		<p class="text-gray-700 mb-4">Une connexion a été effectuée depuis une nouvelle source :</p>

		<!-- Détails -->
		<ul class="space-y-2 bg-gray-50 border border-gray-200 rounded-lg p-4">
			<li class="text-gray-800">
				<strong class="text-blue-900">Appareil :</strong>
				{{ device }}
			</li>
			<li class="text-gray-800">
				<strong class="text-blue-900">Localisation :</strong>
				{{ location }}
			</li>
			<li class="text-gray-800">
				<strong class="text-blue-900">Adresse IP :</strong>
				{{ ip }}
			</li>
			<li class="text-gray-800">
				<strong class="text-blue-900">Date :</strong>
				{{ date|date('d/m/Y H:i') }}
			</li>
		</ul>

		<!-- Avertissement -->
		<p class="mt-6 text-gray-700">
			Si ce n'est pas vous,
			<span class="font-semibold text-red-600">changez immédiatement votre mot de passe</span>.
		</p>
	</div>
{% endblock %}

