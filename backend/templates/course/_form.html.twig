<div class="bg-white p-6 rounded-lg shadow-md border border-gray-100">
	{{ form_start(form, {'attr': {'class': 'space-y-4'}}) }}

	<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
		<div>
			<label class="block text-sm font-medium text-gray-700 mb-1">Diplômes et Formations</label>

			{{ form_widget(form.title, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-600 focus:outline-none'}}) }}
			{% if form_errors(form.title) %}
				<p class="text-red-600 text-xs mt-1">{{ form_errors(form.title) }}</p>
			{% endif %}
		</div>

		<div>
			<label class="block text-sm font-medium text-gray-700 mb-1">Institution</label>
			{{ form_widget(form.institution, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-600 focus:outline-none'}}) }}
			{% if form_errors(form.institution) %}
				<p class="text-red-600 text-xs mt-1">{{ form_errors(form.institution) }}</p>
			{% endif %}
		</div>
	</div>

	<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
		<div>
			<label class="block text-sm font-medium text-gray-700 mb-1">Date de début</label>
			{{ form_widget(form.startDate, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-600 focus:outline-none'}}) }}
		</div>

		<div>
			<label class="block text-sm font-medium text-gray-700 mb-1">Date de fin</label>
			{{ form_widget(form.endDate, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-600 focus:outline-none'}}) }}
		</div>
	</div>

	<div>
		<label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
		{{ form_widget(form.description, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-600 focus:outline-none h-24'}}) }}
		{% if form_errors(form.description) %}
			<p class="text-red-600 text-xs mt-1">{{ form_errors(form.description) }}</p>
		{% endif %}
	</div>

	<div>
		<label class="block text-sm font-medium text-gray-700 mb-1">Utilisateur associé</label>
		{{ form_widget(form.user, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-600 focus:outline-none'}}) }}
	</div>

	<div class="flex justify-end pt-2">
		<button type="submit" class="px-5 py-2 bg-gradient-to-r from-blue-600 to-indigo-600 text-white rounded-md shadow hover:scale-105 transform transition flex items-center space-x-2">
			<span class="material-icons text-sm">save</span>
			<span>{{ button_label|default('Enregistrer') }}</span>
		</button>
	</div>

	{{ form_end(form) }}
</div>
