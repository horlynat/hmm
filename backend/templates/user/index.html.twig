{# templates/user/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Gestion des clients
{% endblock %}

{% block body %}
	<main class="container mx-auto px-4 py-8">

		<!-- 📑 EN-TÊTE -->
		<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
			<div>
				<h1 class="text-3xl font-heading font-bold flex items-center gap-2 text-brand-dark">
					<span class="material-icons text-brand-primary">group</span>
					<span>Clients</span>
				</h1>
				<p class="text-sm opacity-60 mt-1">Gérez les comptes de vos clients.</p>
			</div>
			<a href="{{ path('user_create') }}" class="btn btn-primary gap-2">
				<span class="material-icons text-sm">add_circle</span>
				<span>Ajouter un client</span>
			</a>
		</div>

		<!-- 📊 TABLEAU -->
		<div class="soft-card">
			<table class="table">
				<thead>
					<tr>
						<th class="w-16">Id</th>
						<th>Compte</th>
						<th>Statut</th>
						<th>Inscrit le</th>
						<th class="w-40 text-right">Actions</th>
					</tr>
				</thead>
				<tbody>
					{% for user in users %}
						<tr>
							<td class="font-mono text-xs opacity-50">{{ user.id }}</td>
							<td>
								<div class="flex items-center gap-3">
									<img class="h-9 w-9 rounded-full" src="{{ user.profileImage ?? 'https://ui-avatars.com/api/?name=' ~ (user.fullName ?? user.email)|url_encode }}" alt="{{ user.fullName ?? user.email }}">
									<div>
										<div class="font-bold text-brand-dark">{{ user.fullName ?? 'Non spécifié' }}</div>
										<div class="text-xs opacity-60">{{ user.email }}</div>
									</div>
								</div>
							</td>
							<td>
								{% if user.isActive %}
									<span class="badge bg-success/10 text-success">Actif</span>
								{% else %}
									<span class="badge bg-danger/10 text-danger">Désactivé</span>
								{% endif %}
							</td>
							<td class="text-sm opacity-70">
								{{ user.createdAt ? user.createdAt|date('d/m/Y H:i') : '—' }}
							</td>
							<td>
								<div class="flex items-center justify-end gap-2">
									<a href="{{ path('user_read', {'id': user.id}) }}" class="p-2 hover:bg-brand-light rounded-sm transition-colors text-brand-dark" title="Voir">
										<span class="material-icons text-lg block">visibility</span>
									</a>
									<a href="{{ path('user_update', {'id': user.id}) }}" class="p-2 hover:bg-warning/20 rounded-sm transition-colors text-warning" title="Modifier">
										<span class="material-icons text-lg block">edit</span>
									</a>
									{{ include('user/_delete_form.html.twig', {'user': user}) }}
								</div>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="5" class="text-center py-12 opacity-40">
								<span class="material-icons text-4xl block mb-2">group</span>
								<span>Aucun client trouvé.</span>
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>
	</main>
{% endblock %}
