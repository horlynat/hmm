<!-- Formulaire premium compact -->
<div class="bg-white p-6 rounded-lg shadow-md border border-gray-100">
	{{ form_start(form, {'attr': {'class': 'space-y-4'}}) }}

	<!-- Champ Entreprise -->
	<div>
		<label class="block text-sm font-medium text-gray-700 mb-1">Entreprise</label>
		{{ form_widget(form.company, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-purple-600 focus:outline-none'}}) }}
		{% if form_errors(form.company) %}
			<p class="text-red-600 text-xs mt-1">{{ form_errors(form.company) }}</p>
		{% endif %}
	</div>

	<!-- Champ Rôle -->
	<div>
		<label class="block text-sm font-medium text-gray-700 mb-1">Poste Occupé | responsabilité</label>
		{{ form_widget(form.role, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-purple-600 focus:outline-none'}}) }}
		{% if form_errors(form.role) %}
			<p class="text-red-600 text-xs mt-1">{{ form_errors(form.role) }}</p>
		{% endif %}
	</div>

	<!-- Champ Description -->
	<div>
		<label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
		{{ form_widget(form.description, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-purple-600 focus:outline-none h-24'}}) }}
		{% if form_errors(form.description) %}
			<p class="text-red-600 text-xs mt-1">{{ form_errors(form.description) }}</p>
		{% endif %}
	</div>

	<!-- Champ Dates -->
	<div class="grid grid-cols-2 gap-4">
		<div>
			<label class="block text-sm font-medium text-gray-700 mb-1">Date de début</label>
			{{ form_widget(form.startDate, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-purple-600 focus:outline-none'}}) }}
			{% if form_errors(form.startDate) %}
				<p class="text-red-600 text-xs mt-1">{{ form_errors(form.startDate) }}</p>
			{% endif %}
		</div>
		<div>
			<label class="block text-sm font-medium text-gray-700 mb-1">Date de fin</label>
			{{ form_widget(form.endDate, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-purple-600 focus:outline-none'}}) }}
			{% if form_errors(form.endDate) %}
				<p class="text-red-600 text-xs mt-1">{{ form_errors(form.endDate) }}</p>
			{% endif %}
		</div>
	</div>

	<!-- Champ Utilisateur -->
	<div>
		<label class="block text-sm font-medium text-gray-700 mb-1">Utilisateur</label>
		{{ form_widget(form.user, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-purple-600 focus:outline-none'}}) }}
		{% if form_errors(form.user) %}
			<p class="text-red-600 text-xs mt-1">{{ form_errors(form.user) }}</p>
		{% endif %}
	</div>

	<!-- Bouton CTA -->
	<div class="flex justify-end">
		<button class="px-5 py-2 bg-gradient-to-r from-purple-600 to-pink-600 text-white rounded-md shadow hover:scale-105 transform transition flex items-center space-x-2">
			<span class="material-icons text-sm">save</span>
			<span>{{ button_label|default('Enregistrer') }}</span>
		</button>
	</div>

	{{ form_end(form) }}
</div>

