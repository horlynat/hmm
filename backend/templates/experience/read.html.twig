{% extends 'base.html.twig' %}

{% block title %}Détails de l'expérience
{% endblock %}

{% block body %}
	<main
		class="p-8 bg-gray-50 min-h-screen">

		<!-- Header -->
		<div class="flex justify-between items-center mb-8">
			<h1 class="text-2xl font-bold text-gray-800 flex items-center space-x-2">
				<span class="material-icons text-purple-600">work</span>
				<span>Détails de l'expérience</span>
			</h1>
			<a href="{{ path('experience_index') }}" class="px-5 py-2 bg-gray-200 text-gray-700 rounded-lg shadow hover:bg-gray-300 transition flex items-center space-x-2">
				<span class="material-icons">arrow_back</span>
				<span>Retour à la liste</span>
			</a>
		</div>

		<!-- Card détails -->
		<div class="bg-white p-8 rounded-xl shadow-lg border border-gray-100 space-y-6">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				<div>
					<p class="text-sm text-gray-500">ID</p>
					<p class="text-lg font-semibold text-gray-800">{{ experience.id }}</p>
				</div>
				<div>
					<p class="text-sm text-gray-500">Entreprise</p>
					<p class="text-lg font-semibold text-gray-800">{{ experience.company }}</p>
				</div>
				<div>
					<p class="text-sm text-gray-500">Rôle</p>
					<p class="text-lg font-semibold text-gray-800">{{ experience.role }}</p>
				</div>
				<div>
					<p class="text-sm text-gray-500">Date de début</p>
					<p class="text-lg font-semibold text-gray-800">
						{{ experience.startDate ? experience.startDate|date('d/m/Y') : '—' }}
					</p>
				</div>
				<div>
					<p class="text-sm text-gray-500">Date de fin</p>
					<p class="text-lg font-semibold text-gray-800">
						{{ experience.endDate ? experience.endDate|date('d/m/Y') : '—' }}
					</p>
				</div>
				<div class="md:col-span-2">
					<p class="text-sm text-gray-500">Description</p>
					<p class="text-gray-700 mt-2">{{ experience.description }}</p>
				</div>
			</div>
		</div>

		<!-- Actions -->
		<div class="flex space-x-4 mt-6">
			<a href="{{ path('experience_update', {'id': experience.id}) }}" class="px-5 py-2 bg-yellow-100 text-yellow-700 rounded-lg shadow hover:bg-yellow-200 transition flex items-center space-x-2">
				<span class="material-icons">edit</span>
				<span>Modifier</span>
			</a>
			{{ include('experience/_delete_form.html.twig') }}
		</div>
	</main>
{% endblock %}
