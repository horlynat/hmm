{# templates/components/project/project_table.html.twig #}
<div {{ attributes }} class="relative grid grid-cols-1 xl:grid-cols-12 gap-6">

	{# 🔄 Indicateur Global Asynchrone #}
	<div class="absolute inset-0 bg-white/60 backdrop-blur-[2px] z-50 transition-opacity duration-200 opacity-0 pointer-events-none data-loading:opacity-100 data-loading:pointer-events-auto flex items-center justify-center rounded-xl">
		<div class="animate-spin rounded-full h-12 w-12 border-b-2 border-brand-primary"></div>
	</div>

	{# 📊 COLONNE GAUCHE (xl:col-span-8) : Quick Stats & Tableau #}
	<div class="xl:col-span-8 space-y-6">
		{# Statuts Horizontaux #}
		<div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
			{% for statusCase in statuses|default([]) %}
				<button type="button" data-action="live#update" data-live-name-param="status" data-live-value-param="{{ this.status == statusCase.value ? '' : statusCase.value }}" class="soft-card p-4 text-left border-2 transition-all cursor-pointer {{ this.status == statusCase.value ? 'border-brand-primary bg-brand-light/10 font-bold' : 'border-gray-100 hover:border-gray-200' }}">
					<span class="block text-xs text-gray-400 font-semibold uppercase tracking-wider mb-1">{{ statusCase.label }}</span>
					<span class="text-xl font-extrabold text-brand-dark">
						{{ projectsByStatus[statusCase.value]['count']|default(0) }}
					</span>
				</button>
			{% endfor %}
		</div>

		{# Tableau Principal #}
		<div class="soft-card overflow-hidden shadow-xs">
			<div class="px-6 py-4 border-b border-gray-100 bg-gray-50/75 flex justify-between items-center">
				<h2 class="heading text-base font-bold m-0 text-brand-dark">Console de Contrôle Flotte</h2>
				<span class="text-xs text-gray-500 font-medium font-mono bg-white px-2 py-1 rounded border border-gray-100">
					{{ totalItems|default(0) }} résultat(s)
				</span>
			</div>

			<div class="overflow-x-auto">
				<table class="table whitespace-nowrap">
					<thead>
						<tr>
							<th class="cursor-pointer select-none" data-action="live#action" data-live-action-param="changeSort" data-live-column-param="title">Project
								{% if this.sort == 'title' %}
									{{ this.direction == 'asc' ? '▲' : '▼' }}
								{% endif %}
							</th>
							<th>Client</th>
							<th class="cursor-pointer select-none" data-action="live#action" data-live-action-param="changeSort" data-live-column-param="budget">Budget
								{% if this.sort == 'budget' %}
									{{ this.direction == 'asc' ? '▲' : '▼' }}
								{% endif %}
							</th>
							<th class="cursor-pointer select-none" data-action="live#action" data-live-action-param="changeSort" data-live-column-param="progress">Avancement
								{% if this.sort == 'progress' %}
									{{ this.direction == 'asc' ? '▲' : '▼' }}
								{% endif %}
							</th>
							<th class="cursor-pointer select-none" data-action="live#action" data-live-action-param="changeSort" data-live-column-param="deadline">Échéance
								{% if this.sort == 'deadline' %}
									{{ this.direction == 'asc' ? '▲' : '▼' }}
								{% endif %}
							</th>
							<th>Statut</th>
							<th class="text-center">Actions</th>
						</tr>
					</thead>
					<tbody>
						{% for project in this.projects %}
							<tr class="transition-colors">
								<td class="font-bold text-brand-dark">
									<a href="{{ path('admin_project_read', {id: project.id}) }}" class="hover:text-brand-primary">{{ project.title }}</a>
								</td>
								<td class="text-gray-600 text-sm">{{ project.client.fullName|default('Orphelin') }}</td>
								<td class="font-semibold text-sm">{{ project.budget|number_format(2, ',', ' ') }} €</td>
								<td>
									<div class="w-24 bg-gray-200 rounded-full h-2">
										<div class="bg-brand-primary h-2 rounded-full" style="width: {{ project.progress|default(0) }}%"></div>
									</div>
									<span class="text-[10px] text-gray-400 font-bold">{{ project.progress|default(0) }}%</span>
								</td>
								<td class="text-sm font-medium">
									{% if project.deadline %}
										<span class="{% if project.deadline|date('Y-m-d') < 'now'|date('Y-m-d') and project.status.value|default(project.status) != 'completed' %}text-red-600 font-bold bg-red-50 px-2 py-0.5 rounded{% else %}text-gray-700{% endif %}">
											{{ project.deadline|date('d/m/Y') }}
										</span>
									{% else %}
										<span class="text-gray-400 italic">Non planifié</span>
									{% endif %}
								</td>
								<td>{{ component('project:badge_status', { status: project.status }) }}</td>
								<td class="text-center">
									<a href="{{ path('admin_project_update', {id: project.id}) }}" class="text-brand-primary text-xs font-bold">Modifier</a>
								</td>
							</tr>
						{% else %}
							<tr>
								<td colspan="7" class="text-center py-10 text-gray-400 italic">Aucun projet trouvé.</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>

		{# Pagination #}
		{% if this.totalPages > 1 %}
			<div class="flex justify-between items-center pt-4 border-t border-gray-100">
				<button type="button" {% if page <= 1 %} disabled class="input-disabled text-xs font-bold px-3 py-1.5 shadow-none" {% else %} data-action="live#update" data-live-name-param="page" data-live-value-param="{{ page - 1 }}" class="btn btn-secondary text-xs px-3 py-1.5" {% endif %}>Précédent</button> 
				<span class="text-xs font-bold text-gray-500">Page {{ page }} sur {{ this.totalPages }} </span> 
				<button type="button" {% if page >= this.totalPages %} disabled class="input-disabled text-xs font-bold px-3 py-1.5 shadow-none" {% else %} data-action="live#update" data-live-name-param="page" data-live-value-param="{{ page + 1 }}" class="btn btn-secondary text-xs px-3 py-1.5" {% endif %}>Suivant</button>
			</div>
		{% endif %}
	</div>
</div>
