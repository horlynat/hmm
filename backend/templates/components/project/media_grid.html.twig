{# templates/components/project/_media_grid.html.twig #}
<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4" {{ attributes }}>
	{% if project.media is empty %}
		<div class="col-span-full py-10 text-center border-2 border-dashed border-gray-200 rounded-xl text-gray-400 bg-white/50">
			<span class="text-3xl block mb-2">📁</span>
			<p class="text-sm font-medium mb-0">Aucun média associé à ce projet.</p>
		</div>
	{% else %}
		{% for media in project.media %}
			<div
				class="group relative rounded-xl border border-gray-100 overflow-hidden bg-white hover:shadow-md transition-all duration-300 flex flex-col justify-between">

				{# Conteneur d'affichage de l'image #}
				<div class="aspect-square flex items-center justify-center overflow-hidden bg-gray-50/50 relative">
					{% if 'image' in media.mimeType %}
						<img src="/uploads/projects/{{ media.filePath }}" alt="{{ media.altText }}" class="object-cover w-full h-full transition-transform duration-500 group-hover:scale-105">
					{% else %}
						<div class="text-center p-4">
							<span class="text-4xl block mb-2">📄</span>
							<span class="text-[10px] text-gray-400 block uppercase font-mono tracking-wider font-bold">{{ media.type }}</span>
						</div>
					{% endif %}
				</div>

				{# Pied de fichier (Nom + Corbeille) #}
				<div class="p-3 bg-gray-50/50 border-t border-gray-100 flex justify-between items-center gap-2">
					<span class="text-[10px] text-gray-500 font-medium truncate max-w-[120px]" title="{{ media.filePath }}">
						{{ media.filePath }}
					</span>

					{% if is_granted(constant('App\\Security\\Voter\\ProjectVoter::EDIT'), project) %}
						{# Formulaire de sécurité couplé à votre contrôleur d'administration #}
						<form action="{{ path('admin_project_delete_media', {id: project.id, mediaId: media.id}) }}" method="POST" onsubmit="return confirm('Confirmer la suppression définitive de ce média ?');" class="inline-block">
							<input type="hidden" name="_token" value="{{ csrf_token('admin_project_delete_media_' ~ media.id) }}">
							<button type="submit" class="text-danger hover:text-red-700 p-1.5 hover:bg-red-50 rounded-lg transition-colors cursor-pointer bg-transparent border-0 flex items-center justify-center" title="Supprimer">
								<svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
								</svg>
							</button>
						</form>
					{% endif %}
				</div>
			</div>
		{% endfor %}
	{% endif %}
</div>
